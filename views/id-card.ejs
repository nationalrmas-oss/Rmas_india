<!DOCTYPE html>
<html lang="hi">
<head>
<meta charset="UTF-8">
<title>RMAS ID Card</title>

<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Devanagari:wght@400;700&display=swap" rel="stylesheet">

<style>
body{
    font-family: Mangal, 'Noto Sans Devanagari', 'Arial Unicode MS', sans-serif;
    background:#f5f5f5;
    display:flex;
    gap:20px;
    padding:20px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
}

/* Hindi font rendering optimization */
body, .card, .card span {
    font-family: Mangal, 'Noto Sans Devanagari', 'Arial Unicode MS', sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

.card{
    width:54mm;
    height:85.6mm;
    border:1px solid #000;
    display:flex;
    flex-direction:column;
    box-sizing:border-box;
    background:#fff;
}

.front{
    position: relative;
}

.front::before{
    content: '';
    position: absolute;
    top: 60%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 25mm;
    height: 25mm;
    background-image: url('data:image/png;base64,<%= rmasLogo || nhraLogo %>');
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    opacity: 0.1;
    z-index: 0;
    pointer-events: none;
}

.front > *{
    position: relative;
    z-index: 1;
}

/* ---------- HEADER ---------- */
.header{
    position: relative;
    color:#fff;
    padding:1mm;
    font-size:2.5mm;
    font-weight:bold;
    display: flex;
    flex-direction: column;
}

.slogan-strip{
    display: flex;
    justify-content: space-between;
    font-size: 1.5mm;
    margin-bottom: 0.2mm;
    line-height: 1.1;
}

.slogan-left, .slogan-center, .slogan-right{
    flex: 1;
    text-align: center;
}

.main-header{
    display: grid;
    grid-template-columns: 6mm 1fr 10mm;
    align-items: center;
    margin-bottom: 0.2mm;
}

.main-header img{
    height: 4mm;
    margin-right: 1mm;
}

.main-header .title{
    font-size: 2.5mm;
    line-height: 1.1;
    text-align: center;
    flex: 1;
}

.registration{
    font-size: 1.5mm;
    text-align: right;
    line-height: 1.1;
}

.org-address{
    font-size: 1.5mm;
    text-align: center;
    line-height: 1.1;
    font-weight: bold;
    color :rgb(0, 0, 0);
    margin-top: 0.4mm;
    padding: 0;
}

/* ---------- PHOTO ---------- */
.photo-box{
    text-align:center;
    margin-top:1mm;
    position:relative;
}

.photo-box img{
    width:18mm;
    height:18mm;
    border:1px solid #000;
    object-fit:cover;
}

.photo-stamp-row{
    display: flex;
    justify-content: center;
    margin-top: 1mm;
    position: relative;
}

.photo-box{
    position: relative;
    display: inline-block;
}

.stamp-box{
    position: absolute;
    bottom: -5mm;
    right: -5mm;
    width: 12mm;
    height: 12mm;
    display: flex;
    align-items: center;
    justify-content: center;
}

.stamp{
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 50%;
}

/* ---------- DETAILS ---------- */
.details{
    padding:2mm;
    font-size:2.4mm;
    flex:1;
}

.field{
    margin-bottom: 1mm;
}

.label{
    font-weight:bold;
    color:rgb(1,0,102);
    display: inline;
}

.value{
    display: inline;
    margin-left: 2mm;
    word-break: break-word;
    line-height: 1.3;
}

/* Dynamic font size for designation based on length */
.value.designation-short {
    font-size: 2.4mm;
}

.value.designation-medium {
    font-size: 2.0mm;
}

.value.designation-long {
    font-size: 1.6mm;
}




.official-text{
    text-align: center;
    font-size: 2mm;
    margin-top: 1mm;
    font-weight: bold;
}

/* ---------- FOOTER ---------- */
.footer{
    background:rgb(254,0,0);
    color:#fff;
    text-align:center;
    font-size:2.4mm;
    padding:1mm;
}

/* ---------- BACK ---------- */
.back .header{
    display: flex;
    align-items: center;
    justify-content: center;
    background:rgb(1,0,102);
    color:#fff;
    font-size:2.5mm;
    font-weight:bold;
    padding:2mm 1mm;
}

.back .content{
    padding:3mm;
    font-size:2.6mm;
    flex:1;
}

.back .qr{
    display:flex;
    justify-content:center;
    margin-top:2mm;
}

.back .qr img{
    width:20mm;
    height:20mm;
}

.back .qr-text{
    text-align: center;
    font-size: 1.8mm;
    margin: 1mm 0;
    font-weight: bold;
}

.back .disclaimer{
    border: 0.5px solid #000;
    padding: 1mm;
    margin: 1mm 0;
    font-size: 1.5mm;
    line-height: 1.2;
    text-align: center;
}

.back .disclaimer div{
    margin-bottom: 0.5mm;
}

.back .disclaimer div:last-child{
    margin-bottom: 0;
}
</style>
</head>

<body>

<!-- ================= FRONT SIDE ================= -->
<div class="card front">

    <div class="header">
        <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 830 50" preserveAspectRatio="none" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: -1;">
            <polygon points="0,0 830,0 0,50" fill="#2b235f" />
            <polygon points="0,50 830,0 830,50" fill="#d92523" />
        </svg>
        <div class="slogan-strip">
            <span class="slogan-left">मानव हित सर्वोपरि</span>
            <span class="slogan-center">सत्यमेव जयते</span>
            <span class="slogan-right">न्याय ही धर्म है</span>
        </div>
        <div class="main-header">
            <img src="data:image/png;base64,<%= rmasLogo || nhraLogo %>">
            <div class="title">
                राष्ट्रीय मानवाधिकार संगठन
            </div>
            <div class="registration">
                पंजीकरण संख्या<br>4120/2020
            </div>
        </div>

    </div>

    <div class="org-address">
        D-2, S/F, Gali No. 9, Best Jyoti Nagar, Shahdara Delhi-94
    </div>

    <div class="photo-stamp-row">
        <div class="photo-box">
            <% if (memberPhoto) { %>
            <img src="data:image/jpeg;base64,<%= memberPhoto %>">
            <% } %>
            <div class="stamp-box">
                <img src="data:image/png;base64,<%= stampImage || 'iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNkYPhfDwAChwGA60e6kgAAAABJRU5ErkJggg==' %>" class="stamp">
            </div>
        </div>
    </div>

    <div class="details">
        <div class="field">
            <span class="label">Name:</span>
            <span class="value"><%= memberName || member.fullName %></span>
        </div>

        <div class="field">
            <span class="label">Father Name:</span>
            <span class="value"><%= fatherName || member.fatherName || member.guardianName %></span>
        </div>

        <div class="field">
            <span class="label">Designation:</span>
            <% 
            const designationText = designation || 'सदस्य / Member';
            const desLen = designationText.length;
            let designationClass = 'designation-short';
            if (desLen > 80) {
              designationClass = 'designation-long';
            } else if (desLen > 50) {
              designationClass = 'designation-medium';
            }
            %>
            <span class="value <%= designationClass %>"><%= designationText %></span>
        </div>

        <div class="field">
            <span class="label">DOB:</span>
            <span class="value"><%= formattedDOB %></span>
        </div>

        <div class="field">
            <span class="label">Blood Group:</span>
            <span class="value"><%= member.bloodGroup || 'N/A' %></span>
        </div>

        <div class="field">
            <span class="label">Jurisdiction:</span>
            <span class="value"><%= jurisdiction || 'All India' %></span>
        </div>

        <div class="field">
            <span class="label">Issued On:</span>
            <span class="value"><%
                const issueDate = new Date();
                const day = String(issueDate.getDate()).padStart(2, '0');
                const month = String(issueDate.getMonth() + 1).padStart(2, '0');
                const year = issueDate.getFullYear();
            %><%= day %>/<%= month %>/<%= year %></span>
        </div>

        <div class="official-text">
            Official Member Identity Card
        </div>
    </div>


    <div class="footer">
        ID: <%= member.membershipId %>
    </div>

</div>

<!-- ================= BACK SIDE ================= -->
<div class="card back">

    <div class="header">
        <div class="title" style="text-align: center;">Rashtriya Manav Adhikar Sangathan</div>
    </div>

    <div class="content">
        <div class="field">
            <span class="label">Mobile:</span>
            <span class="value"><%= member.mobile %></span>
        </div>

        <div class="field">
            <span class="label">Email:</span>
            <span class="value"><%= member.email %></span>
        </div>

        <div class="field">
            <span class="label">Address:</span>
            <span class="value">
                <%= member.houseNo || '' %>,
                <%= villageName || member.village || '' %>,
                <%= blockName || member.block || '' %>,
                <%= districtName || member.district || '' %>,
                <%= stateName || member.state || '' %>,
                <%= member.pincode || '' %>
            </span>
        </div>

        <div class="field">
            <span class="label">Valid Upto:</span>
            <span class="value">
                <%
                  const today = new Date();
                  const validUpto = new Date(today);
                  validUpto.setFullYear(today.getFullYear() + 1);
                %>
                <%= validUpto.toLocaleDateString('en-GB') %>
            </span>
        </div>

        <div class="qr">
            <img src="<%= qrCodeDataURL %>">
        </div>
        <div class="qr-text">
            Scan QR code to verify card authenticity
        </div>
        <div class="disclaimer">
            <div>Issued to the member only.</div>
            <div>Misuse of this card may lead to cancellation.</div>
            <div>The association is not responsible for any illegal activity of the card holder.</div>
        </div>
    </div>

    <div class="footer">
        Authorized ID Card
    </div>

</div>

</body>
</html>