                            <i class="fas fa-moon text-white text-sm md:text-base"></i>
                        </span>
                        <span class="font-medium">Dark Mode</span>
                    </a>
                    <a href="/admin/logout" class="group flex items-center gap-2 md:gap-3 px-4 md:px-6 py-2.5 md:py-3 mx-2 mt-2 rounded-xl text-white hover:bg-gradient-to-r hover:from-red-500 hover:to-red-600 transition-all duration-300 font-semibold bg-gradient-to-r from-red-600 to-red-700 shadow-lg hover:shadow-red-500/30 text-sm md:text-base">
