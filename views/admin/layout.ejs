<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Admin Dashboard' %> - RMAS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {}
            }
        };
    </script>
    <!-- <link rel="stylesheet" href="/css/tailwind.css"> -->
    <style>
        /* Custom Scrollbar Styling */
        .scrollbar-thin {
            scrollbar-width: thin;
            scrollbar-color: rgba(255, 255, 255, 0.2) transparent;
        }
        
        /* Webkit browsers (Chrome, Safari, Edge) */
        .scrollbar-thin::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        
        .scrollbar-thin::-webkit-scrollbar-track {
            background: transparent;
        }
        
        .scrollbar-thin::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 3px;
        }
        
        .scrollbar-thin::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.3);
        }
    </style>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .admin-header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 40;
            /* make header taller to accommodate profile circle */
            padding-top: 0.5rem;
            padding-bottom: 0.5rem;
        }
        .registration-number {
            font-size: 1rem; /* increase size */
            font-weight: 600;
        }
        .admin-body {
            /* push main content below adjusted header height */
            margin-top: calc(120px + 2px);
            height: calc(100vh - 122px) !important;
            /* allow vertical scrolling if content overflows */
            /* overflow: hidden !important; */
            display: flex !important;
        }
        .sidebar-desktop { 
            display: flex !important; 
            flex-direction: column !important;
            height: calc(100vh - 102px) !important;
            overflow-y: auto !important;
            z-index: 45;
            border-radius: 0 0 10px 10px !important;
        }
        /* hamburger button styling */
        .hamburger {
            display: none !important; /* hide on desktop */
            border-radius: 10px;
            position: absolute;
            top: 10px;
            left: 10px;
            z-index: 60;
        }
        @media (max-width: 768px) {
            .hamburger {
                display: block !important; /* show only on mobile */
            }
        }
        /* profile circle in header */
        
        /* menu-scroll-area removed - whole sidebar now scrolls */
        .sidebar-bottom {
            margin-top: auto !important;
            flex-shrink: 0 !important;
        }
        .main-content-area {
            display: flex !important;
            flex-direction: column !important;
            overflow: hidden !important;
            flex: 1;
        }
        .main-content-area main {
            overflow-y: auto !important;
            height: 100% !important;
            flex: 1;
        }
        @media (max-width: 768px) {
            .sidebar-desktop { display: none !important; }
            .admin-body {
                margin-top: calc(130px + 2px) !important;
                height: calc(100vh - 132px) !important;
            }
            .main-content-area {
                width: 100% !important;
                margin-top: 50px !important;
                margin-left: 0 !important;
            }
            .main-content-area main {
                overflow-y: auto !important;
                height: 100% !important;
            }
        }
        @media (min-width: 769px) {
            #mobileSidebar, #mobileBackdrop {
                display: none !important;
            }
        }
    </style>
</head>
<body class="bg-gray-100 dark:bg-gray-900 dark:text-gray-100">
    <!-- WEBSITE HEADER (EXACTLY AS MAIN SITE) -->
    <header class="site-header admin-header">
        <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" viewBox="0 0 830 50" preserveAspectRatio="none" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: -1;">
            <polygon points="0,0 830,0 0,50" fill="#2b235f" />
            <polygon points="0,50 830,0 830,50" fill="#d92523" />
        </svg>
        <div class="slogan-strip">
            <span class="slogan-left">मानव हित सर्वोपरि</span>
            <span class="slogan-center">सत्यमेव जयते</span>
            <span class="slogan-right">न्याय ही धर्म है</span>
        </div>
        <div class="main-header">
            <div class="logo">
                <a href="/"><img src="/images/logo.jpeg" alt="Organization Logo"></a>
            </div>
            <div class="org-name-container">
                <h1>Rashtriya Manav Adhikar Sangathan</h1>
                <p class="org-address">D-2, S/F, Gali No. 9, Best Jyoti Nagar, Shahdara Delhi-94</p>
            </div>
            <div class="header-right">
                <div class="registration-number">Registration number - 4120/2020</div>

            </div>
        </div>
        <div class="nav-bar">
            <button class="hamburger" id="mobileMenuBtn" aria-label="Toggle navigation menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <nav>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/about">About Us</a></li>
                    <li><a href="/team">Our Team</a></li>
                    <li><a href="/activities">Activities</a></li>
                    <li><a href="/news">News</a></li>
                    <li><a href="/gallery">Gallery</a></li>
                    <li><a href="/join">Join Us</a></li>
                    <li><a href="/download-verify">Documents</a></li>
                <li><a href="/contact" data-key="nav_contact">Contact Us</a></li>
                <!-- Admin Login Link -->
                <li><a href="/admin/login" style="color: #d92523; font-weight: bold;">🔐 Admin Login</a></li>
                </ul>
            </nav>
            <div class="search-bar">
            <input type="text" placeholder="Search..." data-key="search_placeholder" data-attr="placeholder">
            <i class="search-icon"></i>
        </div>
        <div class="lang-toggle">
            <select id="language-selector">
                <option value="en">EN</option>
                <option value="hi">HI</option>
                <option value="ur">UR</option>
            </select>
        </div>
        </div>
    </header>

    <!-- MAIN CONTENT AREA (2DP BELOW HEADER) -->
    <div class="admin-body flex">
        <!-- SIDEBAR - Desktop -->
        <div class="sidebar-desktop w-64 bg-gradient-to-b from-indigo-900 via-blue-900 to-indigo-950 text-white fixed shadow-2xl" style="top: 138px; left: 0;">
            <!-- Decorative gradient orb -->
            <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-purple-500/20 to-transparent rounded-full blur-2xl"></div>
            <div class="absolute bottom-20 left-0 w-24 h-24 bg-gradient-to-tr from-blue-500/10 to-transparent rounded-full blur-xl"></div>
            
            <!-- Header/Admin Info -->
            <div class="p-6 border-b border-white/10 flex-shrink-0 relative z-10">
                <div class="flex items-center justify-center mb-4">
