<!-- News Ticker -->
<section class="py-8 bg-blue-900 text-white">
  <div class="container mx-auto px-4">
    <h3 class="text-xl font-bold mb-4"><%= t('news.title') %></h3>
    <div class="overflow-hidden">
      <div class="animate-marquee whitespace-nowrap">
        <span class="text-lg"><%= t('news.item1') %> | New initiatives launched | Community outreach programs</span>
      </div>
    </div>
  </div>
</section>

<!-- CTA Banner -->
<section class="py-16 bg-gradient-to-r from-blue-900 to-blue-800 text-white">
  <div class="container mx-auto px-4 text-center">
    <h2 class="text-4xl font-bold mb-4"><%= t('cta.title') %></h2>
    <p class="text-xl mb-8">Stand up for justice and human rights. Your voice matters.</p>
    <a href="/join" class="bg-yellow-500 hover:bg-yellow-600 text-blue-900 font-bold py-3 px-8 rounded-lg transition duration-300 transform hover:scale-105"><%= t('cta.button') %></a>
  </div>
</section>

<style>
  .animate-marquee {
    animation: marquee 20s linear infinite;
  }
  @keyframes marquee {
    0% { transform: translateX(100%); }
    100% { transform: translateX(-100%); }
  }
  html {
    scroll-behavior: smooth;
  }
</style>