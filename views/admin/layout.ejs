            </nav>
        </div> <!-- end mobileSidebar -->

        <!-- Main Content -->
        <div class="main-content-area md:ml-64">
            <main class="p-4 md:p-8" style="padding-top: 50px;">
                <%- body %>
            </main>
        </div>
    </div>

    <style>
        /* Mobile: 50px top padding */
        @media (max-width: 767px) {
            .main-content-area main {
                padding-top: 50px !important;
            }
        }
        /* Desktop: normal padding */
        @media (min-width: 768px) {
            .main-content-area main {
                padding-top: 2rem !important;
            }
        }
    </style>

    <script>
        // Mobile sidebar toggle - using the header hamburger button
        const mobileMenuBtn = document.getElementById('mobileMenuBtn');
        const mobileSidebarClose = document.getElementById('mobileSidebarClose');
        const mobileSidebar = document.getElementById('mobileSidebar');
        const mobileBackdrop = document.getElementById('mobileBackdrop');

        function openMobileSidebar() {
            if (mobileSidebar) {
                mobileSidebar.style.transform = 'translateX(0)';
                mobileSidebar.classList.remove('hidden');
            }
            if (mobileBackdrop) {
                mobileBackdrop.classList.remove('hidden');
            }
        }

        function closeMobileSidebar() {
            if (mobileSidebar) {
                mobileSidebar.style.transform = 'translateX(-100%)';
                setTimeout(() => {
                    mobileSidebar.classList.add('hidden');
                }, 300);
            }
            if (mobileBackdrop) {
                mobileBackdrop.classList.add('hidden');
            }
        }

        // Connect hamburger button to open sidebar
        if (mobileMenuBtn) {
            mobileMenuBtn.addEventListener('click', openMobileSidebar);
        }

        // Close button inside sidebar
        if (mobileSidebarClose) {
            mobileSidebarClose.addEventListener('click', closeMobileSidebar);
        }

        // Click outside to close
        if (mobileBackdrop) {
            mobileBackdrop.addEventListener('click', closeMobileSidebar);
        }

        // Close when clicking nav links
        if (mobileSidebar) {
            mobileSidebar.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', closeMobileSidebar);
            });
        }

        // Auto close mobile sidebar when resizing to desktop
        window.addEventListener('resize', () => {
            if (window.innerWidth > 768) {
                closeMobileSidebar();
            }
        });

        // Dark mode toggle
        const darkToggle = document.getElementById('darkModeToggle');
        function setDarkMode(enabled) {
            if (enabled) {
                document.documentElement.classList.add('dark');
                localStorage.setItem('darkMode','true');
            } else {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('darkMode','false');
            }
        }
        if (darkToggle) {
            // initialize from storage
            const stored = localStorage.getItem('darkMode');
            if (stored === 'true') setDarkMode(true);

            darkToggle.addEventListener('click', (e) => {
                e.preventDefault();
                const isDark = document.documentElement.classList.contains('dark');
                setDarkMode(!isDark);
            });
        }
    </script>
</body>
</html>

