<div class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100 p-6">
    <div class="max-w-7xl mx-auto">
        <!-- Header Section -->
        <div class="bg-white rounded-xl shadow-lg p-6 mb-6 border border-blue-100">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                <div>
                    <h1 class="text-3xl font-bold text-gray-800 mb-2">📋 Membership Applications</h1>
                    <p class="text-gray-600">Review and manage new member applications</p>
                </div>
                <div class="flex items-center gap-4">
                    <div class="bg-blue-100 text-blue-800 px-4 py-2 rounded-full text-sm font-medium">
                        Total: <%= applications.length %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filters Section -->
        <div class="bg-white rounded-xl shadow-lg p-6 mb-6 border border-blue-100">
            <form method="GET" class="flex flex-col lg:flex-row gap-4">
                <div class="flex-1">
                    <label class="block text-sm font-medium text-gray-700 mb-2">🔍 Search Applications</label>
                    <input type="text" name="search" placeholder="Search by name, mobile, or email..." value="<%= search || '' %>"
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                </div>
                <div class="lg:w-48">
                    <label class="block text-sm font-medium text-gray-700 mb-2">📊 Filter by Status</label>
                    <select name="status" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors">
                        <option value="">All Status</option>
                        <option value="pending" <%= status==='pending'?'selected':''%>>⏳ Pending</option>
                        <option value="verified" <%= status==='verified'?'selected':''%>>✅ Verified</option>
                        <option value="approved" <%= status==='approved'?'selected':''%>>🎉 Approved</option>
                    </select>
                </div>
                <div class="lg:w-auto flex items-end">
                    <button type="submit" class="w-full lg:w-auto px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors shadow-md hover:shadow-lg">
                        🔍 Apply Filters
                    </button>
                </div>
            </form>
        </div>

        <!-- Error Message -->
        <% if (typeof error !== 'undefined') { %>
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6">
                <div class="flex items-center">
                    <span class="text-red-500 mr-2">⚠️</span>
                    <%= error === 'notfound' ? 'Application not found.' : error %>
                </div>
            </div>
        <% } %>

        <!-- Applications Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
            <% if (applications.length === 0) { %>
                <div class="col-span-full">
                    <div class="bg-white rounded-xl shadow-lg p-12 text-center border border-gray-200">
                        <div class="text-6xl mb-4">📭</div>
                        <h3 class="text-xl font-semibold text-gray-800 mb-2">No Applications Found</h3>
                        <p class="text-gray-600">Try adjusting your search filters or check back later.</p>
                    </div>
                </div>
            <% } else { %>
                <% applications.forEach(app => { %>
                    <div class="bg-white rounded-xl shadow-lg hover:shadow-xl transition-shadow border border-gray-200 overflow-hidden">
                        <!-- Application Header -->
                        <div class="bg-gradient-to-r from-blue-500 to-indigo-600 p-4">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center space-x-3">
                                    <% if (app.photo) { %>
                                        <img src="/uploads/<%= app.photo %>" alt="photo" class="w-12 h-12 rounded-full object-cover border-2 border-white" onerror="this.style.display='none'">
                                    <% } else { %>
                                        <div class="w-12 h-12 bg-white bg-opacity-20 rounded-full flex items-center justify-center">
                                            <span class="text-white font-bold text-lg"><%= app.fullName.charAt(0).toUpperCase() %></span>
                                        </div>
                                    <% } %>
                                    <div>
                                        <h3 class="font-semibold text-white text-lg"><%= app.fullName %></h3>
                                        <p class="text-blue-100 text-sm"><%= app.district %>, <%= app.state %></p>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <% let statusConfig = { pending: { color: 'yellow', icon: '⏳' }, verified: { color: 'blue', icon: '✅' }, approved: { color: 'green', icon: '🎉' } }[app.status] || { color: 'gray', icon: '❓' }; %>
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-white bg-opacity-20 text-white">
                                        <%= statusConfig.icon %> <%= app.status.charAt(0).toUpperCase() + app.status.slice(1) %>
                                    </span>
                                </div>
                            </div>
                        </div>

                        <!-- Application Details -->
                        <div class="p-6">
                            <div class="space-y-3">
                                <div class="flex items-center text-gray-600">
                                    <span class="text-gray-400 mr-3">📱</span>
                                    <span class="font-medium"><%= app.mobile %></span>
                                </div>
                                <% if (app.email) { %>
                                    <div class="flex items-center text-gray-600">
                                        <span class="text-gray-400 mr-3">✉️</span>
                                        <span class="font-medium"><%= app.email %></span>
                                    </div>
                                <% } %>
                                <div class="flex items-center text-gray-600">
                                    <span class="text-gray-400 mr-3">📅</span>
                                    <span class="font-medium"><%= app.createdAt.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                                </div>
                                <div class="flex items-center text-gray-600">
                                    <span class="text-gray-400 mr-3">🏛️</span>
                                    <span class="font-medium"><%= app.division %></span>
                                </div>
                            </div>

                            <!-- Action Button -->
                            <div class="mt-6 pt-4 border-t border-gray-200">
                                <a href="/admin/membership-applications/<%= app._id %>"
                                   class="w-full inline-flex items-center justify-center px-4 py-3 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors shadow-md hover:shadow-lg">
                                    👁️ View Details
                                </a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </div>
</div>