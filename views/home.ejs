<!-- Hero Section -->
<section class="relative bg-cover bg-center h-screen flex items-center justify-center text-white" style="background-image: url('https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80'); filter: blur(0px);">
  <div class="absolute inset-0 bg-black bg-opacity-50"></div>
  <div class="relative z-10 text-center px-4">
    <h1 class="text-5xl md:text-7xl font-bold mb-4"><%= t('hero.title1') %></h1>
    <p class="text-xl md:text-2xl mb-8"><%= t('hero.title2') %></p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/join" class="bg-blue-900 hover:bg-blue-800 text-white font-bold py-3 px-6 rounded-lg transition duration-300 transform hover:scale-105"><%= t('hero.joinUs') %></a>
      <a href="/about" class="bg-yellow-500 hover:bg-yellow-600 text-blue-900 font-bold py-3 px-6 rounded-lg transition duration-300 transform hover:scale-105"><%= t('hero.knowMore') %></a>
    </div>
  </div>
</section>

<!-- Stats Counter -->
<section class="py-16 bg-gray-100">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="text-center bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition duration-300">
        <div class="text-4xl font-bold text-blue-900 mb-2">5000+</div>
        <p class="text-gray-700"><%= t('stats.members') %></p>
      </div>
      <div class="text-center bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition duration-300">
        <div class="text-4xl font-bold text-blue-900 mb-2">38+</div>
        <p class="text-gray-700"><%= t('stats.districts') %></p>
      </div>
      <div class="text-center bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition duration-300">
        <div class="text-4xl font-bold text-blue-900 mb-2">1200+</div>
        <p class="text-gray-700"><%= t('stats.cases') %></p>
      </div>
      <div class="text-center bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition duration-300">
        <div class="text-4xl font-bold text-blue-900 mb-2">24/7</div>
        <p class="text-gray-700"><%= t('stats.helpline') %></p>
      </div>
    </div>
  </div>
</section>

<!-- About Snapshot -->
<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-12 text-blue-900"><%= t('about.title') %></h2>
    <div class="flex flex-col md:flex-row items-center gap-8">
      <div class="md:w-1/3">
        <img src="/images/placeholder.jpg" alt="<%= t('about.president') %>" class="w-48 h-48 rounded-full mx-auto object-cover shadow-lg">
        <p class="text-center mt-4 font-semibold text-blue-900"><%= t('about.president') %></p>
      </div>
      <div class="md:w-2/3">
        <ul class="list-disc list-inside text-gray-700 text-lg space-y-2">
          <li><%= t('about.mission') %></li>
          <li>Empowering communities through legal aid and awareness</li>
          <li>Advocating for justice and equality</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- Team Cards -->
<section class="py-16 bg-gray-100">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-12 text-blue-900"><%= t('team.title') %></h2>
    <div class="grid grid-cols-1 md:grid-cols-5 gap-8">
      <div class="bg-white p-6 rounded-lg shadow-lg text-center hover:shadow-xl transition duration-300">
        <div class="text-4xl text-blue-900 mb-4"><i class="fas fa-users"></i></div>
        <h3 class="font-semibold"><%= t('team.core') %></h3>
      </div>
      <div class="bg-white p-6 rounded-lg shadow-lg text-center hover:shadow-xl transition duration-300">
        <div class="text-4xl text-blue-900 mb-4"><i class="fas fa-female"></i></div>
        <h3 class="font-semibold"><%= t('team.mahila') %></h3>
      </div>
      <div class="bg-white p-6 rounded-lg shadow-lg text-center hover:shadow-xl transition duration-300">
        <div class="text-4xl text-blue-900 mb-4"><i class="fas fa-user-graduate"></i></div>
        <h3 class="font-semibold"><%= t('team.yuva') %></h3>
      </div>
      <div class="bg-white p-6 rounded-lg shadow-lg text-center hover:shadow-xl transition duration-300">
        <div class="text-4xl text-blue-900 mb-4"><i class="fas fa-handshake"></i></div>
        <h3 class="font-semibold"><%= t('team.minority') %></h3>
      </div>
      <div class="bg-white p-6 rounded-lg shadow-lg text-center hover:shadow-xl transition duration-300">
        <div class="text-4xl text-blue-900 mb-4"><i class="fas fa-laptop"></i></div>
        <h3 class="font-semibold"><%= t('team.it') %></h3>
      </div>
    </div>
  </div>
</section>

<!-- News Ticker -->
<section class="py-8 bg-blue-900 text-white">
  <div class="container mx-auto px-4">
    <h3 class="text-xl font-bold mb-4"><%= t('news.title') %></h3>
    <div class="overflow-hidden">
      <div class="animate-marquee whitespace-nowrap">
        <span class="text-lg"><%= t('news.item1') %> | New initiatives launched | Community outreach programs</span>
      </div>
    </div>
  </div>
</section>

<!-- CTA Banner -->
<section class="py-16 bg-gradient-to-r from-blue-900 to-blue-800 text-white">
  <div class="container mx-auto px-4 text-center">
    <h2 class="text-4xl font-bold mb-4"><%= t('cta.title') %></h2>
    <p class="text-xl mb-8">Stand up for justice and human rights. Your voice matters.</p>
    <a href="/join" class="bg-yellow-500 hover:bg-yellow-600 text-blue-900 font-bold py-3 px-8 rounded-lg transition duration-300 transform hover:scale-105"><%= t('cta.button') %></a>
  </div>
</section>

<style>
  .animate-marquee {
    animation: marquee 20s linear infinite;
  }
  @keyframes marquee {
    0% { transform: translateX(100%); }
    100% { transform: translateX(-100%); }
  }
  html {
    scroll-behavior: smooth;
  }
</style>