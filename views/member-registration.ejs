<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Member Registration Form</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- <link rel="stylesheet" href="/css/tailwind.css"> -->
    <style>
        .form-section {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        .input-field {
            transition: all 0.3s ease;
        }
        .input-field:focus {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }
        .loading-spinner {
            display: inline-block;
            width: 16px;
            height: 16px;
            border: 2px solid #f3f3f3;
            border-top: 2px solid #667eea;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        .error-message {
            color: #dc2626;
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }
        .success-message {
            color: #059669;
            font-size: 0.875rem;
            margin-top: 0.25rem;
        }
    </style>
</head>
<body class="bg-gray-50">
    <div class="min-h-screen py-12 px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mx-auto bg-white rounded-lg shadow-xl overflow-hidden">
            <!-- Header -->
            <div class="form-section px-6 py-8 text-white">
                <h1 class="text-3xl font-bold mb-2">Member Registration Form</h1>
                <p class="text-purple-100">Join our organization and become a member</p>
            </div>

            <!-- Form -->
            <form id="memberForm" enctype="multipart/form-data" class="p-8">
                <!-- Personal Information Section -->
                <div class="mb-8">
                    <h2 class="text-xl font-bold text-gray-800 mb-6 flex items-center">
                        <span class="w-8 h-8 bg-purple-600 text-white rounded-full flex items-center justify-center mr-3 text-sm">1</span>
                        Personal Information
                    </h2>

                    <!-- Full Name -->
                    <div class="mb-6">
                        <label for="fullName" class="block text-sm font-medium text-gray-700 mb-2">Full Name <span class="text-red-500">*</span></label>
                        <input
                            type="text"
                            id="fullName"
                            name="fullName"
                            placeholder="Enter your full name"
                            class="input-field w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent"
                            required
                        />
                        <div class="error-message hidden" id="fullNameError"></div>
                    </div>

                    <!-- Father's Name -->
                    <div class="mb-6">
                        <label for="fatherName" class="block text-sm font-medium text-gray-700 mb-2">Father's Name <span class="text-red-500">*</span></label>
                        <input
                            type="text"
                            id="fatherName"
                            name="fatherName"
                            placeholder="Enter father's name"
                            class="input-field w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent"
                            required
                        />
                        <div class="error-message hidden" id="fatherNameError"></div>
                    </div>

                    <!-- Mobile Number -->
                    <div class="mb-6">
                        <label for="mobile" class="block text-sm font-medium text-gray-700 mb-2">Mobile Number <span class="text-red-500">*</span></label>
                        <input
                            type="tel"
                            id="mobile"
                            name="mobile"
                            pattern="[0-9]{10}"
                            placeholder="Enter 10-digit mobile number"
                            maxlength="10"
                            class="input-field w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent"
                            required
                        />
                        <div class="error-message hidden" id="mobileError"></div>
                    </div>

                    <!-- Gender -->
                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-700 mb-3">Gender <span class="text-red-500">*</span></label>
                        <div class="flex gap-6">
                            <label class="flex items-center">
                                <input type="radio" name="gender" value="Male" class="w-4 h-4 text-purple-600 cursor-pointer" required>
                                <span class="ml-2 text-gray-700 cursor-pointer">Male</span>
                            </label>
                            <label class="flex items-center">
                                <input type="radio" name="gender" value="Female" class="w-4 h-4 text-purple-600 cursor-pointer" required>
                                <span class="ml-2 text-gray-700 cursor-pointer">Female</span>
                            </label>
                            <label class="flex items-center">
                                <input type="radio" name="gender" value="Other" class="w-4 h-4 text-purple-600 cursor-pointer" required>
                                <span class="ml-2 text-gray-700 cursor-pointer">Other</span>
                            </label>
                        </div>
                        <div class="error-message hidden" id="genderError"></div>
                    </div>

                    <!-- Profile Photo -->
                    <div class="mb-6">
                        <label for="profilePhoto" class="block text-sm font-medium text-gray-700 mb-2">Profile Photo <span class="text-red-500">*</span></label>
                        <div class="relative">
                            <input
                                type="file"
                                id="profilePhoto"
                                name="profilePhoto"
                                accept="image/jpeg,image/png,image/jpg"
                                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent cursor-pointer"
                                required
                            />
                            <p class="text-xs text-gray-500 mt-2">Accepted formats: JPG, PNG (Max. 5MB)</p>
                        </div>
                        <div id="photoPreview" class="mt-3 hidden">
                            <img id="photoImage" src="" alt="Preview" class="h-24 w-24 object-cover rounded-lg border-2 border-purple-300" />
                        </div>
                        <div class="error-message hidden" id="photoError"></div>
                    </div>
                </div>

                <!-- Location Information Section -->
                <hr class="my-8" />
                <div class="mb-8">
                    <h2 class="text-xl font-bold text-gray-800 mb-6 flex items-center">
                        <span class="w-8 h-8 bg-purple-600 text-white rounded-full flex items-center justify-center mr-3 text-sm">2</span>
                        Location Details
                    </h2>

                    <!-- State Selection -->
                    <div class="mb-6">
                        <label for="state" class="block text-sm font-medium text-gray-700 mb-2">State <span class="text-red-500">*</span></label>
                        <select
                            id="state"
                            name="state"
                            class="input-field w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent"
                            required
                        >
                            <option value="">-- Select State --</option>
                        </select>
                        <div class="error-message hidden" id="stateError"></div>
                    </div>

                    <!-- Division Selection -->
                    <div class="mb-6">
                        <label for="division" class="block text-sm font-medium text-gray-700 mb-2">Division <span class="text-red-500">*</span></label>
                        <div class="flex items-center gap-2">
                            <select
                                id="division"
                                name="division"
                                class="input-field flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent"
                                disabled
                                required
                            >
                                <option value="">-- Select Division --</option>
                            </select>
                            <div id="divisionLoader" class="loading-spinner hidden"></div>
                        </div>
                        <div class="error-message hidden" id="divisionError"></div>
                    </div>

                    <!-- District Selection -->
                    <div class="mb-6">
                        <label for="district" class="block text-sm font-medium text-gray-700 mb-2">District <span class="text-red-500">*</span></label>
                        <div class="flex items-center gap-2">
                            <select
                                id="district"
                                name="district"
                                class="input-field flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent"
                                disabled
                                required
                            >
                                <option value="">-- Select District --</option>
                            </select>
                            <div id="districtLoader" class="loading-spinner hidden"></div>
                        </div>
                        <div class="error-message hidden" id="districtError"></div>
                    </div>

                    <!-- Block Selection -->
                    <div class="mb-6">
                        <label for="block" class="block text-sm font-medium text-gray-700 mb-2">Block <span class="text-red-500">*</span></label>
                        <div class="flex items-center gap-2">
                            <select
                                id="block"
                                name="block"
                                class="input-field flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent"
                                disabled
                                required
                            >
                                <option value="">-- Select Block --</option>
                            </select>
                            <div id="blockLoader" class="loading-spinner hidden"></div>
                        </div>
                        <div class="error-message hidden" id="blockError"></div>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="flex gap-4 mt-8">
                    <button
                        type="reset"
                        class="flex-1 px-6 py-3 bg-gray-300 text-gray-800 font-semibold rounded-lg hover:bg-gray-400 transition duration-200"
                    >
                        Clear Form
                    </button>
                    <button
                        type="submit"
                        class="flex-1 px-6 py-3 bg-purple-600 text-white font-semibold rounded-lg hover:bg-purple-700 transition duration-200 flex items-center justify-center gap-2"
                    >
                        <span>Submit Registration</span>
                        <span id="submitLoader" class="loading-spinner hidden"></span>
                    </button>
                </div>

                <!-- Success Message -->
                <div id="successMessage" class="hidden mt-6 p-4 bg-green-50 border border-green-200 rounded-lg">
                    <p class="text-green-800 font-semibold">✓ Registration submitted successfully!</p>
                </div>
            </form>
        </div>
    </div>

    <!-- Include the reusable location system -->
    <script src="/js/location-system.js"></script>

    <script>
        // Initialize Location System for Member Registration Form
        // The LocationSystem class handles all state/division/district/block logic
        let locationSystem;
        
        // DOM Elements
        const form = document.getElementById('memberForm');
        const stateSelect = document.getElementById('state');
        const profilePhotoInput = document.getElementById('profilePhoto');
        const photoPreview = document.getElementById('photoPreview');
        const photoImage = document.getElementById('photoImage');
        const fullNameInput = document.getElementById('fullName');
        const fatherNameInput = document.getElementById('fatherName');
        const mobileInput = document.getElementById('mobile');
        const submitLoader = document.getElementById('submitLoader');

        /**
         * Show error message
         * @param {string} field - Field name
         * @param {string} message - Error message
         */
        function showError(field, message) {
            const errorElement = document.getElementById(`${field}Error`);
            if (errorElement) {
                errorElement.textContent = message;
                errorElement.classList.remove('hidden');
            }
        }

        /**
         * Hide error message
         * @param {string} field - Field name
         */
        function hideError(field) {
            const errorElement = document.getElementById(`${field}Error`);
            if (errorElement) {
                errorElement.classList.add('hidden');
                errorElement.textContent = '';
            }
        }

        // Initialize location system when DOM is ready
        document.addEventListener('DOMContentLoaded', function() {
            locationSystem = initLocationSystem('state', 'division', 'district', 'block');
        });

        /**
         * Handle Profile Photo Upload and Preview
         */
        profilePhotoInput.addEventListener('change', function (event) {
            hideError('profilePhoto');
            const file = event.target.files[0];

            if (!file) {
                photoPreview.classList.add('hidden');
                return;
            }

            // Validate file size (5MB max)
            const maxSize = 5 * 1024 * 1024; // 5MB
            if (file.size > maxSize) {
                showError('profilePhoto', 'File size must not exceed 5MB');
                profilePhotoInput.value = '';
                photoPreview.classList.add('hidden');
                return;
            }

            // Validate file type
            const validTypes = ['image/jpeg', 'image/png', 'image/jpg'];
            if (!validTypes.includes(file.type)) {
                showError('profilePhoto', 'Only JPG and PNG files are allowed');
                profilePhotoInput.value = '';
                photoPreview.classList.add('hidden');
                return;
            }

            // Show preview
            const reader = new FileReader();
            reader.onload = function (e) {
                photoImage.src = e.target.result;
                photoPreview.classList.remove('hidden');
                console.log('✅ Photo preview loaded');
            };
            reader.readAsDataURL(file);
        });

        /**
         * Form Validation
         */
        function validateForm() {
            let isValid = true;

            // Validate Full Name
            if (!fullNameInput.value.trim()) {
                showError('fullName', 'Full name is required');
                isValid = false;
            } else {
                hideError('fullName');
            }

            // Validate Father's Name
            if (!fatherNameInput.value.trim()) {
                showError('fatherName', "Father's name is required");
                isValid = false;
            } else {
                hideError('fatherName');
            }

            // Validate Mobile Number
            const mobileValue = mobileInput.value.trim();
            if (!mobileValue) {
                showError('mobile', 'Mobile number is required');
                isValid = false;
            } else if (!/^\d{10}$/.test(mobileValue)) {
                showError('mobile', 'Mobile number must be 10 digits');
                isValid = false;
            } else {
                hideError('mobile');
            }

            // Validate Gender
            const genderChecked = document.querySelector('input[name="gender"]:checked');
            if (!genderChecked) {
                showError('gender', 'Gender is required');
                isValid = false;
            } else {
                hideError('gender');
            }

            // Validate Profile Photo
            if (!profilePhotoInput.files.length) {
                showError('profilePhoto', 'Profile photo is required');
                isValid = false;
            } else {
                hideError('profilePhoto');
            }

            // Validate State
            if (!stateSelect.value) {
                showError('state', 'State is required');
                isValid = false;
            } else {
                hideError('state');
            }

            // Validate Division
            const divisionSelect = document.getElementById('division');
            if (!divisionSelect.value) {
                showError('division', 'Division is required');
                isValid = false;
            } else {
                hideError('division');
            }

            // Validate District
            const districtSelect = document.getElementById('district');
            if (!districtSelect.value) {
                showError('district', 'District is required');
                isValid = false;
            } else {
                hideError('district');
            }

            // Validate Block
            const blockSelect = document.getElementById('block');
            if (!blockSelect.value) {
                showError('block', 'Block is required');
                isValid = false;
            } else {
                hideError('block');
            }

            return isValid;
        }

        /**
         * Handle Form Submission
         */
        form.addEventListener('submit', async function (event) {
            event.preventDefault();

            // Validate form
            if (!validateForm()) {
                console.warn('⚠️ Form validation failed');
                return;
            }

            submitLoader.classList.remove('hidden');

            try {
                // Create FormData object
                const formData = new FormData(form);

                console.log('📤 Submitting member registration...');

                // Submit form (adjust endpoint as needed)
                const response = await fetch('/api/members/register', {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) {
                    throw new Error(`Server error: ${response.status}`);
                }

                const result = await response.json();

                // Show success message
                document.getElementById('successMessage').classList.remove('hidden');
                console.log('✅ Registration submitted successfully:', result);

                // Reset form after 2 seconds
                setTimeout(() => {
                    form.reset();
                    photoPreview.classList.add('hidden');
                    locationSystem.resetAll();
                    document.getElementById('successMessage').classList.add('hidden');
                    // Scroll to top
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                }, 2000);
            } catch (error) {
                console.error('❌ Error submitting registration:', error);
                alert(`Error: ${error.message}`);
            } finally {
                submitLoader.classList.add('hidden');
            }
        });

        /**
         * Clear form and reset on reset button click
         */
        form.addEventListener('reset', function () {
            photoPreview.classList.add('hidden');
            locationSystem.resetAll();
            document.getElementById('successMessage').classList.add('hidden');
            // Clear all error messages
            document.querySelectorAll('.error-message').forEach(elem => {
                elem.classList.add('hidden');
                elem.textContent = '';
            });
            console.log('🔄 Form reset');
        });

        // Log when page loads
        window.addEventListener('load', function () {
            console.log('📄 Member Registration Form loaded successfully');
        });
    </script>
</body>
</html>
