<% var error = typeof error !== 'undefined' ? error : null;
   var success = typeof success !== 'undefined' ? success : null;
   var downloads = typeof downloads !== 'undefined' ? downloads : null;
   var memberId = typeof memberId !== 'undefined' ? memberId : null;
%>
<div class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100 p-6">
    <div class="max-w-md mx-auto">
        <div class="bg-white rounded-xl shadow-lg p-8 border border-blue-100">
            <h1 class="text-3xl font-bold text-center text-gray-800 mb-8">Download Documents</h1>

            <% if (error) { %>
                <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6">
                    <%= error %>
                </div>
            <% } %>

            <% if (success) { %>
                <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6">
                    <%= success %>
                </div>
            <% } %>

            <% if (downloads) { %>
                <div class="space-y-4">
                    <h2 class="text-xl font-semibold text-gray-800">Download Your Documents</h2>
                    <a href="<%= downloads.idCard %>" target="_blank" class="block w-full px-6 py-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg text-center transition-colors text-lg">
                        Download ID Card (PDF)
                    </a>
                    <a href="<%= downloads.joiningLetter %>" target="_blank" class="block w-full px-6 py-4 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-lg text-center transition-colors text-lg">
                        Download Joining Letter (PDF)
                    </a>
                </div>
            <% } else if (memberId) { %>
                <form action="/verify-otp" method="POST">
                    <input type="hidden" name="memberId" value="<%= memberId %>">
                    <div class="mb-6">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Enter OTP</label>
                        <input type="text" name="otp" required class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none transition-colors text-gray-800" placeholder="6-digit OTP">
                    </div>
                    <button type="submit" class="w-full px-4 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors">
                        Verify OTP
                    </button>
                </form>
            <% } else { %>
                <form id="downloadForm" action="/download-verify" method="POST">
                    <div class="mb-6">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Full Name *</label>
                        <input type="text" name="fullName" required class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none transition-colors text-gray-800" placeholder="Enter your full name">
                    </div>
                    <div class="mb-6">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Date of Birth (DD/MM/YYYY) *</label>
                        <input type="text" id="dobInput" name="dob" required placeholder="14/08/2002" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none transition-colors text-gray-800" maxlength="10">
                        <small class="text-gray-500 text-xs mt-1 block">Enter as DD/MM/YYYY (slashes added automatically)</small>
                    </div>
                    <div class="mb-6">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Email *</label>
                        <input type="email" name="email" required class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none transition-colors text-gray-800" placeholder="Enter your email">
                    </div>
                    <button type="submit" class="w-full px-4 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors">
                        Send OTP
                    </button>
                </form>
                <script>
                    // Auto-format DOB input with slashes
                    const dobInput = document.getElementById('dobInput');
                    const downloadForm = document.getElementById('downloadForm');
                    
                    if (dobInput) {
                        dobInput.addEventListener('input', function(e) {
                            let value = e.target.value.replace(/\D/g, ''); // Remove non-digits
                            
                            if (value.length >= 2) {
                                value = value.slice(0, 2) + '/' + value.slice(2);
                            }
                            if (value.length >= 5) {
                                value = value.slice(0, 5) + '/' + value.slice(5);
                            }
                            value = value.slice(0, 10); // Limit to DD/MM/YYYY
                            
                            e.target.value = value;
                        });
                    }
                    
                    // Validate on form submission
                    if (downloadForm) {
                        downloadForm.addEventListener('submit', function(e) {
                            const dob = dobInput.value.trim();
                            const dobRegex = /^\d{2}\/\d{2}\/\d{4}$/;
                            
                            if (!dobRegex.test(dob)) {
                                e.preventDefault();
                                alert('Please enter date in DD/MM/YYYY format (e.g., 14/08/2002)');
                                dobInput.focus();
                                return false;
                            }
                        });
                    }
                </script>
            <% } %>

            <div class="mt-8 text-center">
                <a href="/" class="text-blue-600 hover:text-blue-800">Back to Home</a>
            </div>
        </div>
    </div>
</div>