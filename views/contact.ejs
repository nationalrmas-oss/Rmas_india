<!-- Hero Section -->
<section class="hero-gradient text-white py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-center"><%= t('contact.heroTitle') %></h1>
        <p class="text-lg md:text-xl text-center text-blue-100"><%= t('contact.heroSubtitle') %></p>
    </div>
</section>

<!-- Contact Information Cards -->
<section class="py-16 md:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            
            <!-- Address Card -->
            <div class="card-hover bg-white rounded-lg border border-gray-200 p-8 text-center <%= dir === 'rtl' ? 'text-right' : 'text-left' %>">
                <div class="text-4xl mb-4 text-blue-600"><%= t('contact.office.icon') %></div>
                <h3 class="text-2xl font-bold text-gray-800 mb-3"><%= t('contact.officeTitle') %></h3>
                <p class="text-lg font-semibold text-gray-700 mb-2"><%= t('contact.office.name') %></p>
                <p class="text-gray-600 leading-relaxed"><%= t('contact.office.address') %></p>
            </div>

            <!-- Helpline Card -->
            <div class="card-hover bg-white rounded-lg border border-gray-200 p-8 text-center <%= dir === 'rtl' ? 'text-right' : 'text-left' %>">
                <div class="text-4xl mb-4 text-green-600"><%= t('contact.helpline.icon') %></div>
                <h3 class="text-2xl font-bold text-gray-800 mb-3"><%= t('contact.helplineTitle') %></h3>
                <p class="text-lg font-semibold text-gray-700 mb-2"><%= t('contact.helpline.title') %></p>
                <a href="tel:<%= t('contact.helpline.number').replace(/\s+/g, '') %>" class="text-2xl font-bold text-blue-600 hover:text-blue-800 transition mb-3 block">
                    <%= t('contact.helpline.number') %>
                </a>
                <p class="text-sm text-gray-600"><%= t('contact.helpline.person') %></p>
            </div>

            <!-- Email Card -->
            <div class="card-hover bg-white rounded-lg border border-gray-200 p-8 text-center <%= dir === 'rtl' ? 'text-right' : 'text-left' %>">
                <div class="text-4xl mb-4 text-red-600"><%= t('contact.email.icon') %></div>
                <h3 class="text-2xl font-bold text-gray-800 mb-3"><%= t('contact.emailTitle') %></h3>
                <p class="text-sm text-gray-600 mb-2"><%= t('contact.email.title') %></p>
                <a href="mailto:<%= t('contact.email.address') %>" class="text-lg font-semibold text-blue-600 hover:text-blue-800 transition block mb-3">
                    <%= t('contact.email.address') %>
                </a>
                <a href="mailto:<%= t('contact.email.support') %>" class="text-sm text-gray-600 hover:text-gray-800 transition block">
                    <%= t('contact.email.support') %>
                </a>
            </div>

        </div>
    </div>
</section>

<!-- Contact Form -->
<section class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4">
        <div class="bg-white rounded-lg shadow-lg p-8 md:p-12">
            <h2 class="text-3xl font-bold text-gray-800 mb-8 <%= dir === 'rtl' ? 'text-right' : 'text-left' %>">
                <%= t('contact.formTitle') %>
            </h2>

            <form id="contactForm" class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Name -->
                    <div>
                        <label for="name" class="block text-sm font-semibold text-gray-700 mb-2">
                            <%= t('contact.formFields.name') %> <span class="text-red-600">*</span>
                        </label>
                        <input 
                            type="text" 
                            id="name" 
                            name="name" 
                            required
                            placeholder="<%= t('contact.formFields.name') %>"
                            class="form-input w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-400"
                        />
                    </div>

                    <!-- Phone -->
                    <div>
                        <label for="phone" class="block text-sm font-semibold text-gray-700 mb-2">
                            <%= t('contact.formFields.phone') %> <span class="text-red-600">*</span>
                        </label>
                        <input 
                            type="tel" 
                            id="phone" 
                            name="phone" 
                            required
                            placeholder="+91 XXXXX XXXXX"
                            pattern="^[0-9]{10,15}$"
                            class="form-input w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-400"
                        />
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- District -->
                    <div>
                        <label for="district" class="block text-sm font-semibold text-gray-700 mb-2">
                            <%= t('contact.formFields.district') %> <span class="text-red-600">*</span>
                        </label>
                        <select 
                            id="district" 
                            name="district" 
                            required
                            class="form-input w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-400"
                        >
                            <option value="">-- <%= t('contact.formFields.district') %> --</option>
                            <option value="Delhi">Delhi</option>
                            <option value="Bihar">Bihar</option>
                            <option value="Uttar Pradesh">Uttar Pradesh</option>
                            <option value="Jharkhand">Jharkhand</option>
                            <option value="West Bengal">West Bengal</option>
                            <option value="Madhya Pradesh">Madhya Pradesh</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>

                    <!-- Subject -->
                    <div>
                        <label for="subject" class="block text-sm font-semibold text-gray-700 mb-2">
                            <%= t('contact.formFields.subject') %> <span class="text-red-600">*</span>
                        </label>
                        <select 
                            id="subject" 
                            name="subject" 
                            required
                            class="form-input w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-400"
                        >
                            <option value="">-- <%= t('contact.formFields.subject') %> --</option>
                            <% subjectOptions.forEach(subject => { %>
                                <option value="<%= subject %>"><%= subject %></option>
                            <% }); %>
                        </select>
                    </div>
                </div>

                <!-- Message -->
                <div>
                    <label for="message" class="block text-sm font-semibold text-gray-700 mb-2">
                        <%= t('contact.formFields.message') %> <span class="text-red-600">*</span>
                    </label>
                    <textarea 
                        id="message" 
                        name="message" 
                        required
                        rows="6"
                        placeholder="<%= t('contact.formFields.placeholder_message') %>"
                        class="form-input w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-400 resize-none"
                    ></textarea>
                </div>

                <!-- Submit Button -->
                <div class="<%= dir === 'rtl' ? 'text-left' : 'text-right' %>">
                    <button 
                        type="submit" 
                        class="btn-submit text-white font-bold py-3 px-8 rounded-lg"
                    >
                        <%= t('contact.formFields.submit') %>
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>

<!-- Google Map -->
<section class="py-16 md:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-gray-800 mb-8 text-center"><%= t('contact.mapTitle') %></h2>
        <div class="rounded-lg overflow-hidden shadow-lg h-96">
            <iframe 
                width="100%" 
                height="100%" 
                frameborder="0" 
                style="border:0" 
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3500.568403825627!2d77.31404847347207!3d28.600547675261636!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x390ce50d5e3c3333%3A0x1d8f8f8f8f8f8f8f!2sShahara%2C%20Delhi!5e0!3m2!1sen!2sin!4v1234567890" 
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade">
            </iframe>
        </div>
    </div>
</section>

<!-- Social Media Links -->
<section class="bg-blue-900 text-white py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-8"><%= t('contact.socialTitle') %></h2>
        <div class="flex justify-center gap-6 md:gap-10 flex-wrap">
            <!-- Facebook -->
            <a 
                href="<%= t('contact.socialLinks.facebook') %>" 
                target="_blank" 
                rel="noopener noreferrer"
                class="bg-blue-600 hover:bg-blue-700 text-white rounded-full p-4 transition transform hover:scale-110 duration-300"
            >
                <i class="fab fa-facebook-f text-2xl"></i>
            </a>

            <!-- Twitter -->
            <a 
                href="<%= t('contact.socialLinks.twitter') %>" 
                target="_blank" 
                rel="noopener noreferrer"
                class="bg-blue-400 hover:bg-blue-500 text-white rounded-full p-4 transition transform hover:scale-110 duration-300"
            >
                <i class="fab fa-twitter text-2xl"></i>
            </a>

            <!-- Instagram -->
            <a 
                href="<%= t('contact.socialLinks.instagram') %>" 
                target="_blank" 
                rel="noopener noreferrer"
                class="bg-pink-600 hover:bg-pink-700 text-white rounded-full p-4 transition transform hover:scale-110 duration-300"
            >
                <i class="fab fa-instagram text-2xl"></i>
            </a>

            <!-- YouTube -->
            <a 
                href="<%= t('contact.socialLinks.youtube') %>" 
                target="_blank" 
                rel="noopener noreferrer"
                class="bg-red-600 hover:bg-red-700 text-white rounded-full p-4 transition transform hover:scale-110 duration-300"
            >
                <i class="fab fa-youtube text-2xl"></i>
            </a>
        </div>
    </div>
</section>

<style>
    .hero-gradient { background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); }
    .card-hover { transition: all 0.3s ease; }
    .card-hover:hover { transform: translateY(-8px); box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1); }
    .form-input { transition: border-color 0.3s ease; }
    .form-input:focus { border-color: #3b82f6; outline: none; box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1); }
    .btn-submit { background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); transition: all 0.3s ease; }
    .btn-submit:hover { transform: scale(1.02); box-shadow: 0 10px 20px rgba(30, 58, 138, 0.3); }
</style>

<script>
    // Form submission handler
    document.getElementById('contactForm').addEventListener('submit', function(e) {
        e.preventDefault();
        
        const formData = {
            name: document.getElementById('name').value,
            phone: document.getElementById('phone').value,
            district: document.getElementById('district').value,
            subject: document.getElementById('subject').value,
            message: document.getElementById('message').value,
            language: '<%= lang %>'
        };

        // Log form data (in a real application, this would be sent to a server)
        console.log('Contact Form Submitted:', formData);

        // Show success message
        alert('Thank you for your message! We will get back to you soon.');
        
        // Reset form
        this.reset();
    });

    // Phone number input validation
    document.getElementById('phone').addEventListener('input', function() {
        this.value = this.value.replace(/[^0-9]/g, '').slice(0, 15);
    });
</script>
