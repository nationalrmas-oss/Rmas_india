<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="mb-8">
    <h2 class="text-3xl font-bold text-indigo-900">📊 Reports & Analytics</h2>
    <p class="text-gray-600 mt-2">Comprehensive membership and activity analytics dashboard</p>
  </div>

  <!-- Summary Cards - Top Row -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <!-- Total Members Card -->
    <div class="bg-gradient-to-br from-blue-500 to-blue-700 rounded-xl shadow-lg p-6 text-white transition-transform duration-300 hover:scale-105 hover:shadow-2xl cursor-pointer">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-blue-100 text-sm font-medium">Total Members</p>
          <p class="text-4xl font-bold mt-2"><%= totals.total || 0 %></p>
          <p class="text-blue-200 text-xs mt-2">Across all levels</p>
        </div>
        <div class="bg-white/20 rounded-full p-3">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
        </div>
      </div>
    </div>

    <!-- Accepted Members Card -->
    <div class="bg-gradient-to-br from-emerald-500 to-emerald-700 rounded-xl shadow-lg p-6 text-white transition-transform duration-300 hover:scale-105 hover:shadow-2xl cursor-pointer">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-emerald-100 text-sm font-medium">✅ Accepted</p>
          <p class="text-4xl font-bold mt-2"><%= totals.accepted || 0 %></p>
          <p class="text-emerald-200 text-xs mt-2"><%= ((totals.accepted / (totals.total || 1) * 100) || 0).toFixed(1) %>% of total</p>
        </div>
        <div class="bg-white/20 rounded-full p-3">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
      </div>
    </div>

    <!-- Pending Card -->
    <div class="bg-gradient-to-br from-amber-500 to-orange-600 rounded-xl shadow-lg p-6 text-white transition-transform duration-300 hover:scale-105 hover:shadow-2xl cursor-pointer">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-amber-100 text-sm font-medium">⏳ Pending</p>
          <p class="text-4xl font-bold mt-2"><%= appStatus.pending || 0 %></p>
          <p class="text-amber-200 text-xs mt-2"><%= appStatus.claimed || 0 %> claimed</p>
        </div>
        <div class="bg-white/20 rounded-full p-3">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
      </div>
      <div class="mt-3 bg-white/20 rounded-lg px-3 py-1">
        <span class="text-sm">Awaiting approval</span>
      </div>
    </div>

    <!-- Downloads Card -->
    <div class="bg-gradient-to-br from-purple-500 to-pink-600 rounded-xl shadow-lg p-6 text-white transition-transform duration-300 hover:scale-105 hover:shadow-2xl cursor-pointer">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-purple-100 text-sm font-medium">📥 Downloads</p>
          <p class="text-4xl font-bold mt-2"><%= totalDownloads || 0 %></p>
          <p class="text-purple-200 text-xs mt-2">Documents downloaded</p>
        </div>
        <div class="bg-white/20 rounded-full p-3">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Charts Section - Middle Row -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <!-- Status Distribution Chart (Doughnut) -->
    <div class="bg-white rounded-xl shadow-lg p-6 hover:shadow-2xl transition-shadow duration-300">
      <h3 class="text-lg font-semibold text-gray-800 mb-4 flex items-center">
        <span class="w-2 h-2 bg-blue-500 rounded-full mr-2"></span>
        Status Distribution
      </h3>
      <div class="relative h-64">
        <canvas id="statusChart"></canvas>
      </div>
    </div>

    <!-- Team Distribution Chart (Bar) -->
    <div class="bg-white rounded-xl shadow-lg p-6 hover:shadow-2xl transition-shadow duration-300">
      <h3 class="text-lg font-semibold text-gray-800 mb-4 flex items-center">
        <span class="w-2 h-2 bg-purple-500 rounded-full mr-2"></span>
        Team Type Distribution
      </h3>
      <div class="relative h-64">
        <canvas id="teamChart"></canvas>
      </div>
    </div>
  </div>

  <!-- Charts Section - Bottom Row (Full Width) -->
  <div class="grid grid-cols-1 gap-6 mb-8">
    <!-- Monthly Growth Chart (Area/Line) -->
    <div class="bg-white rounded-xl shadow-lg p-6 hover:shadow-2xl transition-shadow duration-300">
      <h3 class="text-lg font-semibold text-gray-800 mb-4 flex items-center">
        <span class="w-2 h-2 bg-teal-500 rounded-full mr-2"></span>
        Monthly Growth (Last 12 Months)
      </h3>
      <div class="relative h-72">
        <canvas id="growthChart"></canvas>
      </div>
    </div>

    <!-- Daily Downloads Chart (Line) -->
    <div class="bg-white rounded-xl shadow-lg p-6 hover:shadow-2xl transition-shadow duration-300">
      <h3 class="text-lg font-semibold text-gray-800 mb-4 flex items-center">
        <span class="w-2 h-2 bg-pink-500 rounded-full mr-2"></span>
        Daily Downloads (Last 30 Days)
      </h3>
      <div class="relative h-72">
        <canvas id="downloadsChart"></canvas>
      </div>
    </div>
  </div>

  <!-- Location Summary Table -->
  <div class="bg-white rounded-xl shadow-lg p-6 mb-8 hover:shadow-2xl transition-shadow duration-300">
    <h3 class="text-lg font-semibold text-gray-800 mb-4 flex items-center">
      <span class="w-2 h-2 bg-indigo-500 rounded-full mr-2"></span>
      Top Locations
    </h3>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="bg-gradient-to-r from-indigo-50 to-purple-50 border-b-2 border-indigo-100">
            <th class="px-4 py-3 text-left text-sm font-semibold text-indigo-900">State</th>
            <th class="px-4 py-3 text-left text-sm font-semibold text-indigo-900">Division</th>
            <th class="px-4 py-3 text-left text-sm font-semibold text-indigo-900">District</th>
            <th class="px-4 py-3 text-right text-sm font-semibold text-indigo-900">Members</th>
          </tr>
        </thead>
        <tbody>
          <% if (locationData && locationData.length > 0) { %>
            <% locationData.forEach((loc, idx) => { %>
              <tr class="border-b border-gray-100 hover:bg-indigo-50/50 transition-colors duration-200">
                <td class="px-4 py-3 text-gray-700"><%= loc._id.state || '-' %></td>
                <td class="px-4 py-3 text-gray-700"><%= loc._id.division || '-' %></td>
                <td class="px-4 py-3 text-gray-700"><%= loc._id.district || '-' %></td>
                <td class="px-4 py-3 text-right font-bold text-indigo-600"><%= loc.count %></td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="4" class="px-4 py-8 text-center text-gray-500">No location data available</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Export Button -->
  <div class="bg-white rounded-xl shadow-lg p-6 mb-8 hover:shadow-2xl transition-shadow duration-300">
    <h3 class="text-lg font-semibold text-gray-800 mb-4 flex items-center">
      <span class="w-2 h-2 bg-green-500 rounded-full mr-2"></span>
      Export Reports
    </h3>
    <form method="POST" action="/admin/reports-analytics/export" class="flex flex-wrap gap-4 items-center">
      <select name="reportType" class="px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none">
        <option value="summary">Summary Report</option>
        <option value="members">Members Details</option>
        <option value="downloads">Document Downloads</option>
      </select>
      <button type="submit" class="px-6 py-2 bg-gradient-to-r from-green-500 to-emerald-600 text-white font-semibold rounded-lg hover:from-green-600 hover:to-emerald-700 transition-all duration-200 shadow-md hover:shadow-lg flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
        </svg>
        Export as CSV
      </button>
    </form>
  </div>

  <!-- Info Box -->
  <div class="bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-200 rounded-xl p-5">
    <div class="flex items-start gap-3">
      <div class="bg-blue-100 p-2 rounded-lg">
        <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>
      <div class="text-gray-700">
        <strong class="text-blue-900">Dashboard Information:</strong>
        <ul class="mt-2 space-y-1 text-sm">
          <li>• Last updated: <%= new Date().toLocaleString('en-IN') %></li>
          <li>• Your role: <strong class="text-indigo-700"><%= currentUser.role %></strong></li>
          <% if (currentUser.location && currentUser.location.state) { %>
            <li>• Viewing data for: <strong class="text-indigo-700"><%= currentUser.location.state %> State</strong> and below</li>
          <% } else if (currentUser.location && currentUser.location.division) { %>
            <li>• Viewing data for: <strong class="text-indigo-700"><%= currentUser.location.division %> Division</strong> and below</li>
          <% } else if (currentUser.location && currentUser.location.district) { %>
            <li>• Viewing data for: <strong class="text-indigo-700"><%= currentUser.location.district %> District</strong></li>
          <% } %>
        </ul>
      </div>
    </div>
  </div>
</div>

<!-- Load Chart.js from CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  // Professional Color Palette
  const chartColors = {
    blue: '#3B82F6',
    purple: '#8B5CF6',
    pink: '#EC4899',
    teal: '#14B8A6',
    amber: '#F59E0B',
    emerald: '#10B981',
    rose: '#F43F5E',
    indigo: '#6366F1',
    cyan: '#06B6D4',
    violet: '#A855F7'
  };

  const colorPalette = [
    chartColors.blue,
    chartColors.purple,
    chartColors.pink,
    chartColors.teal,
    chartColors.amber,
    chartColors.emerald,
    chartColors.rose,
    chartColors.indigo,
    chartColors.cyan,
    chartColors.violet
  ];

  // Status Distribution Chart (Doughnut)
  <%
    const statusData = stats.statusCounts || [];
    const statusLabels = statusData.map(s => (s._id || 'Unknown').toUpperCase());
    const statusValues = statusData.map(s => s.count);
  %>
  <% if (statusLabels.length > 0) { %>
  const statusCtx = document.getElementById('statusChart').getContext('2d');
  new Chart(statusCtx, {
    type: 'doughnut',
    data: {
      labels: <%- JSON.stringify(statusLabels) %>,
      datasets: [{
        data: <%- JSON.stringify(statusValues) %>,
        backgroundColor: colorPalette.slice(0, <%= statusLabels.length %>),
        borderColor: '#ffffff',
        borderWidth: 3,
        hoverOffset: 10
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      cutout: '60%',
      plugins: {
        legend: {
          position: 'bottom',
          labels: {
            padding: 20,
            usePointStyle: true,
            pointStyle: 'circle',
            font: { size: 12, family: 'system-ui' }
          }
        },
        tooltip: {
          backgroundColor: 'rgba(0, 0, 0, 0.8)',
          titleFont: { size: 14, family: 'system-ui' },
          bodyFont: { size: 13, family: 'system-ui' },
          padding: 12,
          cornerRadius: 8
        }
      }
    }
  });
  <% } else { %>
  document.getElementById('statusChart').parentElement.innerHTML = 
    '<div class="flex items-center justify-center h-full text-gray-400">No status data available</div>';
  <% } %>

  // Team Distribution Chart (Bar)
  <%
    const teamData = stats.teamDistribution || [];
    const teamLabels = teamData.map(t => (t._id || 'Unknown'));
    const teamValues = teamData.map(t => t.count);
  %>
  <% if (teamLabels.length > 0) { %>
  const teamCtx = document.getElementById('teamChart').getContext('2d');
  new Chart(teamCtx, {
    type: 'bar',
    data: {
      labels: <%- JSON.stringify(teamLabels) %>,
      datasets: [{
        label: 'Members',
        data: <%- JSON.stringify(teamValues) %>,
        backgroundColor: colorPalette.map(c => c + 'CC'),
        borderColor: colorPalette,
        borderWidth: 2,
        borderRadius: 8,
        borderSkipped: false
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: 'rgba(0, 0, 0, 0.8)',
          titleFont: { size: 14, family: 'system-ui' },
          bodyFont: { size: 13, family: 'system-ui' },
          padding: 12,
          cornerRadius: 8
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          grid: { color: 'rgba(0, 0, 0, 0.05)' },
          ticks: { font: { family: 'system-ui' } }
        },
        x: {
          grid: { display: false },
          ticks: { font: { family: 'system-ui' } }
        }
      }
    }
  });
  <% } else { %>
  document.getElementById('teamChart').parentElement.innerHTML = 
    '<div class="flex items-center justify-center h-full text-gray-400">No team data available</div>';
  <% } %>

  // Monthly Growth Chart (Area/Line)
  <%
    const monthlyData = stats.monthlyGrowth || [];
    const monthLabels = monthlyData.map(m => m._id);
    const monthValues = monthlyData.map(m => m.count);
  %>
  <% if (monthLabels.length > 0) { %>
  const growthCtx = document.getElementById('growthChart').getContext('2d');
  
  // Create gradient for area chart
  const growthGradient = growthCtx.createLinearGradient(0, 0, 0, 300);
  growthGradient.addColorStop(0, 'rgba(59, 130, 246, 0.4)');
  growthGradient.addColorStop(1, 'rgba(59, 130, 246, 0.0)');

  new Chart(growthCtx, {
    type: 'line',
    data: {
      labels: <%- JSON.stringify(monthLabels) %>,
      datasets: [{
        label: 'New Members',
        data: <%- JSON.stringify(monthValues) %>,
        borderColor: chartColors.blue,
        backgroundColor: growthGradient,
        borderWidth: 3,
        fill: true,
        tension: 0.4,
        pointBackgroundColor: chartColors.blue,
        pointBorderColor: '#ffffff',
        pointBorderWidth: 2,
        pointRadius: 5,
        pointHoverRadius: 8
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: 'rgba(0, 0, 0, 0.8)',
          titleFont: { size: 14, family: 'system-ui' },
          bodyFont: { size: 13, family: 'system-ui' },
          padding: 12,
          cornerRadius: 8
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          grid: { color: 'rgba(0, 0, 0, 0.05)' },
          ticks: { font: { family: 'system-ui' } }
        },
        x: {
          grid: { display: false },
          ticks: { font: { family: 'system-ui' } }
        }
      }
    }
  });
  <% } else { %>
  document.getElementById('growthChart').parentElement.innerHTML = 
    '<div class="flex items-center justify-center h-full text-gray-400">No growth data available</div>';
  <% } %>

  // Daily Downloads Chart (Line)
  <%
    const dailyData = downloads.dailyDownloads || [];
    const dayLabels = dailyData.map(d => d._id);
    const dayValues = dailyData.map(d => d.count);
  %>
  <% if (dayLabels.length > 0) { %>
  const downloadsCtx = document.getElementById('downloadsChart').getContext('2d');
  
  // Create gradient for downloads chart
  const downloadsGradient = downloadsCtx.createLinearGradient(0, 0, 0, 300);
  downloadsGradient.addColorStop(0, 'rgba(236, 72, 153, 0.4)');
  downloadsGradient.addColorStop(1, 'rgba(236, 72, 153, 0.0)');

  new Chart(downloadsCtx, {
    type: 'line',
    data: {
      labels: <%- JSON.stringify(dayLabels) %>,
      datasets: [{
        label: 'Downloads',
        data: <%- JSON.stringify(dayValues) %>,
        borderColor: chartColors.pink,
        backgroundColor: downloadsGradient,
        borderWidth: 3,
        fill: true,
        tension: 0.4,
        pointBackgroundColor: chartColors.pink,
        pointBorderColor: '#ffffff',
        pointBorderWidth: 2,
        pointRadius: 4,
        pointHoverRadius: 7
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: 'rgba(0, 0, 0, 0.8)',
          titleFont: { size: 14, family: 'system-ui' },
          bodyFont: { size: 13, family: 'system-ui' },
          padding: 12,
          cornerRadius: 8
        }
      },
      scales: {
        y: {
          beginAtZero: true,
          grid: { color: 'rgba(0, 0, 0, 0.05)' },
          ticks: { font: { family: 'system-ui' } }
        },
        x: {
          grid: { display: false },
          ticks: { 
            font: { family: 'system-ui' },
            maxRotation: 45,
            minRotation: 45
          }
        }
      }
    }
  });
  <% } else { %>
  document.getElementById('downloadsChart').parentElement.innerHTML = 
    '<div class="flex items-center justify-center h-full text-gray-400">No download data available</div>';
  <% } %>
</script>
