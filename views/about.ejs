<!-- Hero Section -->
<section class="py-16 bg-gray-200">
  <div class="container mx-auto px-4 text-center">
    <h1 class="text-4xl md:text-6xl font-bold text-blue-900 mb-4"><%= t('about.heroTitle') %></h1>
    <p class="text-xl md:text-2xl text-gray-700"><%= t('about.heroSubtitle') %></p>
  </div>
</section>

<!-- Our History & Mission -->
<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row items-center gap-8 <%= dir === 'rtl' ? 'md:flex-row-reverse' : '' %>">
      <div class="md:w-1/2">
        <img src="/images/mission.jpg" alt="RMAS Meeting" class="w-full rounded-lg shadow-lg">
      </div>
      <div class="md:w-1/2">
        <h2 class="text-3xl font-bold text-blue-900 mb-6">Our History & Mission</h2>
        <p class="text-lg text-gray-700 mb-4"><strong>History:</strong> <%= t('about.history') %></p>
        <p class="text-lg text-gray-700 mb-4"><strong>Mission:</strong> <%= t('about.mission') %></p>
        <p class="text-lg text-gray-700"><strong>Vision:</strong> <%= t('about.vision') %></p>
      </div>
    </div>
  </div>
</section>

<!-- Core Values -->
<section class="py-16 bg-gray-100">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-12 text-blue-900">Core Values</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="bg-white p-8 rounded-lg shadow-lg text-center hover:shadow-xl transition duration-300">
        <div class="text-6xl text-blue-600 mb-4">⚖️</div>
        <h3 class="text-xl font-semibold mb-2"><%= t('about.coreValues.justice.title') %></h3>
        <p class="text-gray-600"><%= t('about.coreValues.justice.desc') %></p>
      </div>
      <div class="bg-white p-8 rounded-lg shadow-lg text-center hover:shadow-xl transition duration-300">
        <div class="text-6xl text-blue-600 mb-4">🤝</div>
        <h3 class="text-xl font-semibold mb-2"><%= t('about.coreValues.unity.title') %></h3>
        <p class="text-gray-600"><%= t('about.coreValues.unity.desc') %></p>
      </div>
      <div class="bg-white p-8 rounded-lg shadow-lg text-center hover:shadow-xl transition duration-300">
        <div class="text-6xl text-blue-600 mb-4">🛡️</div>
        <h3 class="text-xl font-semibold mb-2"><%= t('about.coreValues.protection.title') %></h3>
        <p class="text-gray-600"><%= t('about.coreValues.protection.desc') %></p>
      </div>
    </div>
  </div>
</section>

<!-- Organizational Structure -->
<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-12 text-blue-900">Organizational Structure</h2>
    <div class="flex flex-col items-center">
      <div class="bg-blue-900 text-white p-4 rounded-lg mb-4 shadow-lg">National Level</div>
      <div class="border-l-2 border-blue-600 h-8"></div>
      <div class="bg-blue-800 text-white p-4 rounded-lg mb-4 shadow-lg">State Level</div>
      <div class="border-l-2 border-blue-600 h-8"></div>
      <div class="bg-blue-700 text-white p-4 rounded-lg mb-4 shadow-lg">Divisional Level</div>
      <div class="border-l-2 border-blue-600 h-8"></div>
      <div class="bg-blue-600 text-white p-4 rounded-lg mb-4 shadow-lg">District Level</div>
      <div class="border-l-2 border-blue-600 h-8"></div>
      <div class="bg-blue-500 text-white p-4 rounded-lg mb-4 shadow-lg">Block/Panchayat Level</div>
    </div>
    <p class="text-center text-lg text-gray-700 mt-8"><%= t('about.structure') %></p>
  </div>
</section>

<!-- President's Message -->
<section class="py-16 bg-gray-100">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-12 text-blue-900">President's Message</h2>
    <div class="max-w-4xl mx-auto bg-white p-8 rounded-lg shadow-lg">
      <div class="flex flex-col md:flex-row items-center gap-8 <%= dir === 'rtl' ? 'md:flex-row-reverse' : '' %>">
        <div class="md:w-1/3">
          <img src="/images/national prasident.jpeg" alt="Saroj Sekha Sengale" class="w-48 h-48 rounded-full mx-auto object-cover object-center shadow-lg" style="object-position: center 30%;">
        </div>
        <div class="md:w-2/3">
          <blockquote class="text-lg text-gray-700 italic mb-6">"<%= t('about.presidentMessage') %>"</blockquote>
          <div class="text-right">
            <p class="font-semibold text-blue-900">Saroj Sekha Sengale</p>
            <p class="text-gray-600">National President</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>