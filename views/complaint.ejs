    <script>
        let currentStep = 1;
        const totalSteps = 4;

        function updateSteps() {
            // Update step indicators
            for (let i = 1; i <= totalSteps; i++) {
                const stepElement = document.getElementById(`step${i}`);
                if (i < currentStep) {
                    stepElement.className = 'step-completed w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm';
                } else if (i === currentStep) {
                    stepElement.className = 'step-active w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm';
                } else {
                    stepElement.className = 'step-inactive w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm';
                }
            }

            // Show/hide form sections
            for (let i = 1; i <= totalSteps; i++) {
                const section = document.getElementById(`step${i}-content`);
                section.classList.toggle('active', i === currentStep);
            }

            // Update navigation buttons
            const prevBtn = document.getElementById('prevBtn');
            const nextBtn = document.getElementById('nextBtn');
            const submitBtn = document.getElementById('submitBtn');

            prevBtn.classList.toggle('hidden', currentStep === 1);
            nextBtn.classList.toggle('hidden', currentStep === totalSteps);
            submitBtn.classList.toggle('hidden', currentStep !== totalSteps);
        }

        function validateCurrentStep() {
            const currentSection = document.getElementById(`step${currentStep}-content`);
            const requiredFields = currentSection.querySelectorAll('[required]');
            let isValid = true;

            requiredFields.forEach(field => {
                if (!field.value.trim()) {
                    field.classList.add('border-red-500');
                    isValid = false;
                } else {
                    field.classList.remove('border-red-500');
                }
            });

            return isValid;
        }

        // Navigation event listeners
        document.getElementById('nextBtn').addEventListener('click', () => {
            if (validateCurrentStep()) {
                if (currentStep < totalSteps) {
                    currentStep++;
                    updateSteps();
                }
            } else {
                alert('<%= t("complaint.validation.requiredFields") %>');
            }
        });

        document.getElementById('prevBtn').addEventListener('click', () => {
            if (currentStep > 1) {
                currentStep--;
                updateSteps();
            }
        });

        // Same as complainant checkbox
        document.getElementById('sameAsComplainant').addEventListener('change', function() {
            const complainantFields = {
                fullName: document.querySelector('[name="complainant_fullName"]').value,
                fatherName: document.querySelector('[name="complainant_fatherName"]').value,
                age: document.querySelector('[name="complainant_age"]').value,
                gender: document.querySelector('[name="complainant_gender"]').value,
                mobile: document.querySelector('[name="victim_contactNumber"]'),
                occupation: document.querySelector('[name="complainant_occupation"]').value
            };

            if (this.checked) {
                document.querySelector('[name="victim_fullName"]').value = complainantFields.fullName;
                document.querySelector('[name="victim_fatherName"]').value = complainantFields.fatherName;
                document.querySelector('[name="victim_age"]').value = complainantFields.age;
                document.querySelector('[name="victim_gender"]').value = complainantFields.gender;
                document.querySelector('[name="victim_occupation"]').value = complainantFields.occupation;
                document.querySelector('[name="victim_contactNumber"]').value = complainantFields.mobile;
            } else {
                document.querySelector('[name="victim_fullName"]').value = '';
                document.querySelector('[name="victim_fatherName"]').value = '';
                document.querySelector('[name="victim_age"]').value = '';
                document.querySelector('[name="victim_gender"]').value = '';
                document.querySelector('[name="victim_occupation"]').value = '';
                document.querySelector('[name="victim_contactNumber"]').value = '';
            }
        });

        // File upload handlers
        ['idProof', 'addressProof', 'medicalReports', 'policeReports'].forEach(fieldName => {
            const input = document.getElementById(fieldName);
            const display = document.getElementById(`${fieldName}Name`);

            input.addEventListener('change', function() {
                if (this.files.length > 0) {
                    if (this.multiple) {
                        const fileNames = Array.from(this.files).map(f => f.name).join(', ');
                        display.textContent = `${this.files.length} files selected: ${fileNames}`;
                    } else {
                        display.textContent = this.files[0].name;
                    }
                } else {
                    display.textContent = '';
                }
            });
        });

        // Form submission
        document.getElementById('complaintForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            if (!validateCurrentStep()) {
                alert('<%= t("complaint.validation.requiredFields") %>');
                return;
            }

            // Show loading state
            const submitBtn = document.getElementById('submitBtn');
            const originalText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i><%= t("complaint.buttons.submitting") %>';
            submitBtn.disabled = true;

            try {
                const formData = new FormData(this);

                const response = await fetch('/api/complaints', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (response.ok) {
                    // Show success message with tracking ID
                    alert('<%= t("complaint.success.message") %>' + result.trackingId);
                    window.location.href = '/complaint/status?trackingId=' + result.trackingId;
                } else {
                    throw new Error(result.message || 'Submission failed');
                }
            } catch (error) {
                console.error('Submission error:', error);
                alert('<%= t("complaint.error.submissionFailed") %>');
            } finally {
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            }
        });

        // Initialize
        updateSteps();
    </script>