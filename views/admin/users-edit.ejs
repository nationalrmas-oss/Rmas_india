<div class="max-w-2xl mx-auto">
    <div class="mb-8">
        <h2 class="text-3xl font-bold text-gray-800">Edit Official</h2>
        <p class="text-gray-600 mt-1"><a href="/admin/dashboard" class="text-blue-600 hover:underline">Home</a> / <a href="/admin/users" class="text-blue-600 hover:underline">Users</a> / Edit Official</p>
    </div>

    <div class="bg-white rounded-lg shadow-md p-8">
        <form id="editUserForm" onsubmit="handleSubmit(event)">
            <!-- Personal Information Section -->
            <h3 class="text-xl font-bold text-gray-800 mb-4 pb-3 border-b-2 border-blue-600">📋 Personal Information</h3>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Full Name *</label>
                    <input 
                        type="text" 
                        name="fullName" 
                        required
                        value="<%= user.fullName %>"
                        placeholder="Enter full name"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-blue-600 focus:ring-2 focus:ring-blue-200"
                    >
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Mobile Number</label>
                    <input 
                        type="tel" 
                        name="phone" 
                        value="<%= user.phone || '' %>"
                        placeholder="10-digit mobile number"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-blue-600 focus:ring-2 focus:ring-blue-200"
                    >
                </div>
            </div>

            <!-- Login Info Section -->
            <h3 class="text-xl font-bold text-gray-800 mb-4 pb-3 border-b-2 border-blue-600">🔐 Login Information</h3>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Username</label>
                    <input 
                        type="text" 
                        value="<%= user.username %>"
                        disabled
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-gray-100 text-gray-600"
                    >
                    <p class="text-xs text-gray-500 mt-1">Username cannot be changed</p>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Email Address *</label>
                    <input 
                        type="email" 
                        name="email" 
                        required
                        value="<%= user.email %>"
                        placeholder="Official email"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-blue-600 focus:ring-2 focus:ring-blue-200"
                    >
                </div>
            </div>

            <!-- Role & Level Section -->
            <h3 class="text-xl font-bold text-gray-800 mb-4 pb-3 border-b-2 border-blue-600 mt-8">👔 Role & Access Level</h3>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Role *</label>
                    <select 
                        name="role" 
                        required
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-blue-600 focus:ring-2 focus:ring-blue-200"
                    >
                        <option value="President" <% if (user.role === 'President') { %>selected<% } %>>President</option>
                        <option value="Secretary" <% if (user.role === 'Secretary') { %>selected<% } %>>Secretary</option>
                        <option value="Media Incharge" <% if (user.role === 'Media Incharge') { %>selected<% } %>>Media Incharge</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Access Level *</label>
                    <select 
                        name="level" 
                        required
                        onchange="updateLocationSelectors()"
                        id="levelSelect"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-blue-600 focus:ring-2 focus:ring-blue-200"
                    >
                        <option value="National" <% if (user.level === 'National') { %>selected<% } %>>National</option>
                        <option value="State" <% if (user.level === 'State') { %>selected<% } %>>State</option>
                        <option value="Division" <% if (user.level === 'Division') { %>selected<% } %>>Division</option>
                        <option value="District" <% if (user.level === 'District') { %>selected<% } %>>District</option>
                        <option value="Block" <% if (user.level === 'Block') { %>selected<% } %>>Block</option>
                        <option value="Panchayat" <% if (user.level === 'Panchayat') { %>selected<% } %>>Panchayat</option>
                    </select>
                </div>
            </div>

            <!-- Location Section -->
            <h3 class="text-xl font-bold text-gray-800 mb-4 pb-3 border-b-2 border-blue-600 mt-8">📍 Location</h3>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div id="stateDiv" style="display: none;">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">State *</label>
                    <select 
                        name="state"
                        id="stateSelect"
                        data-current="<%= user.location?.state || '' %>"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-blue-600 focus:ring-2 focus:ring-blue-200"
                    >
                        <option value="">-- Select State --</option>
                    </select>
                </div>

                <div id="divisionDiv" style="display: none;">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Division *</label>
                    <select 
                        name="division"
                        id="divisionSelect"
                        data-current="<%= user.location?.division || '' %>"
                        onchange="onDivisionChange()"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-blue-600 focus:ring-2 focus:ring-blue-200"
                    >
                        <option value="">-- Select Division --</option>
                    </select>
                </div>

                <div id="districtDiv" style="display: none;">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">District *</label>
                    <select 
                        name="district"
                        id="districtSelect"
                        data-current="<%= user.location?.district || '' %>"
                        onchange="onDistrictChange()"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-blue-600 focus:ring-2 focus:ring-blue-200"
                    >
                        <option value="">-- Select District --</option>
                    </select>
                </div>

                <div id="blockDiv" style="display: none;">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Block *</label>
                    <select 
                        name="block"
                        id="blockSelect"
                        data-current="<%= user.location?.block || '' %>"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-blue-600 focus:ring-2 focus:ring-blue-200"
                    >
                        <option value="">-- Select Block --</option>
                    </select>
                </div>
                <div id="panchayatDiv" style="display: none;">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Panchayat Name *</label>
                    <input
                        type="text"
                        name="panchayat"
                        id="panchayatInput"
                        value="<%= user.location?.panchayat || '' %>"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-blue-600 focus:ring-2 focus:ring-blue-200"
                        placeholder="Enter panchayat name"
                    />
                </div>
            </div>

            <!-- Status Section -->
            <h3 class="text-xl font-bold text-gray-800 mb-4 pb-3 border-b-2 border-blue-600 mt-8">⚙️ Status</h3>

            <div class="mb-6">
                <label class="block text-sm font-semibold text-gray-700 mb-2">Account Status</label>
                <select 
                    name="isActive"
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-blue-600 focus:ring-2 focus:ring-blue-200"
                >
                    <option value="true" <% if (user.isActive) { %>selected<% } %>>✅ Active</option>
                    <option value="false" <% if (!user.isActive) { %>selected<% } %>>❌ Inactive</option>
                </select>
            </div>

            <!-- Submit & Cancel -->
            <div class="flex gap-4 mt-8">
                <button 
                    type="submit"
                    class="px-6 py-3 bg-blue-600 text-white font-bold rounded-lg hover:bg-blue-700 transition"
                >
                    ✅ Save Changes
                </button>
                <a href="/admin/users" class="px-6 py-3 bg-gray-300 text-gray-700 font-bold rounded-lg hover:bg-gray-400 transition">
                    ❌ Cancel
                </a>
            </div>
        </form>

        <!-- Error/Success Messages -->
        <div id="message" style="display: none; margin-top: 20px;" class="p-4 rounded-lg">
        </div>
    </div>
</div>

<!-- Include the reusable location system -->
<script src="/js/location-system.js"></script>

<script>
    // Initialize location selectors on load
    document.addEventListener('DOMContentLoaded', function() {
        initLocationSystem('stateSelect','divisionSelect','districtSelect','blockSelect');
        restrictLevelOptions();
        lockToAdminArea();
        populateCurrentLocation();
    });

    function restrictLevelOptions() {
        const admin = <%- JSON.stringify(admin) %>;
        if (!admin || admin.role === 'Superadmin') return;
        const hierarchy = { 'National':5, 'State':4, 'Division':3, 'District':2, 'Block':1, 'Panchayat':0 };
        const rank = hierarchy[admin.level] || 0;
        const select = document.getElementById('levelSelect');
        Array.from(select.options).forEach(opt => {
            if (opt.value && hierarchy[opt.value] > rank) {
                opt.disabled = true;
            }
        });
    }

    // Lock location selectors to the current admin's own geographic area (only if not Super Admin)
    function lockToAdminArea() {
        const admin = <%- JSON.stringify(admin) %>;
        if (!admin || admin.role === 'Superadmin') return;
        // depending on admin.level, prefill and disable fields
        if (admin.level === 'State' && admin.location.state) {
            document.getElementById('stateSelect').value = admin.location.state;
            document.getElementById('stateSelect').disabled = true;
        }
        if (admin.level === 'Division' && admin.location.division) {
            document.getElementById('stateSelect').value = admin.location.state;
            document.getElementById('stateSelect').disabled = true;
            document.getElementById('divisionSelect').value = admin.location.division;
            document.getElementById('divisionSelect').disabled = true;
        }
        if (admin.level === 'District' && admin.location.district) {
            document.getElementById('stateSelect').value = admin.location.state;
            document.getElementById('stateSelect').disabled = true;
            document.getElementById('divisionSelect').value = admin.location.division;
            document.getElementById('divisionSelect').disabled = true;
            document.getElementById('districtSelect').value = admin.location.district;
            document.getElementById('districtSelect').disabled = true;
        }
        if (admin.level === 'Block' && admin.location.block) {
            document.getElementById('stateSelect').value = admin.location.state;
            document.getElementById('stateSelect').disabled = true;
            document.getElementById('divisionSelect').value = admin.location.division;
            document.getElementById('divisionSelect').disabled = true;
            document.getElementById('districtSelect').value = admin.location.district;
            document.getElementById('districtSelect').disabled = true;
            document.getElementById('blockSelect').value = admin.location.block;
            document.getElementById('blockSelect').disabled = true;
        }
    }

    // Populate current location values and trigger cascading loads
    async function populateCurrentLocation() {
        const stateSelect = document.getElementById('stateSelect');
        const divisionSelect = document.getElementById('divisionSelect');
        const districtSelect = document.getElementById('districtSelect');
        const blockSelect = document.getElementById('blockSelect');

        const currentState = stateSelect.dataset.current;
        const currentDivision = divisionSelect.dataset.current;
        const currentDistrict = districtSelect.dataset.current;
        const currentBlock = blockSelect.dataset.current;

        if (currentState) {
            stateSelect.value = currentState;
            // Trigger division load
            const stateFile = currentState.toLowerCase().replace(/\s+/g, '_') + '.json';
            try {
                const response = await fetch(`/locations/${stateFile}`);
                if (response.ok) {
                    const data = await response.json();
                    divisionSelect.innerHTML = '<option value="">-- Select Division --</option>';
                    if (data.divisions) {
                        Object.keys(data.divisions).forEach(div => {
                            const option = document.createElement('option');
                            option.value = div;
                            option.textContent = div;
                            divisionSelect.appendChild(option);
                        });
                    }
                    if (currentDivision) {
                        divisionSelect.value = currentDivision;
                        // Trigger district load
                        if (data.divisions && data.divisions[currentDivision] && data.divisions[currentDivision].districts) {
                            districtSelect.innerHTML = '<option value="">-- Select District --</option>';
                            Object.keys(data.divisions[currentDivision].districts).forEach(dist => {
                                const option = document.createElement('option');
                                option.value = dist;
                                option.textContent = dist;
                                districtSelect.appendChild(option);
                            });
                            if (currentDistrict) {
                                districtSelect.value = currentDistrict;
                                // Trigger block load
                                if (data.divisions[currentDivision].districts[currentDistrict] && data.divisions[currentDivision].districts[currentDistrict].blocks) {
                                    blockSelect.innerHTML = '<option value="">-- Select Block --</option>';
                                    data.divisions[currentDivision].districts[currentDistrict].blocks.forEach(block => {
                                        const option = document.createElement('option');
                                        option.value = block;
                                        option.textContent = block;
                                        blockSelect.appendChild(option);
                                    });
                                    if (currentBlock) {
                                        blockSelect.value = currentBlock;
                                    }
                                }
                            }
                        }
                    }
                }
            } catch (error) {
                console.error('Error populating current location:', error);
            }
        }
    }

    function updateLocationSelectors() {
        const level = document.getElementById('levelSelect').value;
        
        // hide/select visibility
        document.getElementById('stateDiv').style.display = 'none';
        document.getElementById('divisionDiv').style.display = 'none';
        document.getElementById('districtDiv').style.display = 'none';
        document.getElementById('blockDiv').style.display = 'none';
        document.getElementById('panchayatDiv').style.display = 'none';
        
        if (level === 'State') {
            document.getElementById('stateDiv').style.display = 'block';
        } else if (level === 'Division') {
            document.getElementById('stateDiv').style.display = 'block';
            document.getElementById('divisionDiv').style.display = 'block';
        } else if (level === 'District') {
            document.getElementById('stateDiv').style.display = 'block';
            document.getElementById('divisionDiv').style.display = 'block';
            document.getElementById('districtDiv').style.display = 'block';
        } else if (level === 'Block') {
            document.getElementById('stateDiv').style.display = 'block';
            document.getElementById('divisionDiv').style.display = 'block';
            document.getElementById('districtDiv').style.display = 'block';
            document.getElementById('blockDiv').style.display = 'block';
        } else if (level === 'Panchayat') {
            document.getElementById('stateDiv').style.display = 'block';
            document.getElementById('divisionDiv').style.display = 'block';
            document.getElementById('districtDiv').style.display = 'block';
            document.getElementById('blockDiv').style.display = 'block';
            document.getElementById('panchayatDiv').style.display = 'block';
        }
    }

    async function handleSubmit(event) {
        event.preventDefault();
        
        const formData = new FormData(event.target);
        const data = Object.fromEntries(formData.entries());
        
        try {
            const response = await fetch(`/admin/users/<%= user._id %>/edit`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data),
            });
            
            const result = await response.json();
            
            const messageDiv = document.getElementById('message');
            if (result.success) {
                messageDiv.className = 'p-4 rounded-lg bg-green-100 text-green-800';
                messageDiv.textContent = result.message || 'User updated successfully!';
                messageDiv.style.display = 'block';
                setTimeout(() => {
                    window.location.href = '/admin/users';
                }, 2000);
            } else {
                messageDiv.className = 'p-4 rounded-lg bg-red-100 text-red-800';
                messageDiv.textContent = result.error || 'Failed to update user.';
                messageDiv.style.display = 'block';
            }
        } catch (error) {
            console.error('Error:', error);
            const messageDiv = document.getElementById('message');
            messageDiv.className = 'p-4 rounded-lg bg-red-100 text-red-800';
            messageDiv.textContent = 'Network error. Please try again.';
            messageDiv.style.display = 'block';
        }
    }
</script>
