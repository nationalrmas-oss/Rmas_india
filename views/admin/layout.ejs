                    </div>
                </div>
                <h3 class="text-center font-bold text-base md:text-lg text-white"><%= admin.fullName %></h3>
                <p class="text-center text-xs md:text-sm text-blue-300 bg-blue-800/30 py-1 px-3 rounded-full mt-2 inline-block"><%= admin.role %></p>
            </div>

            <!-- Scrollable Menu Content -->
            <nav class="flex-1 overflow-y-auto overflow-x-hidden py-3 scrollbar-thin scrollbar-thumb-white/20 scrollbar-track-transparent">
                <p class="px-4 md:px-6 py-2 text-xs font-bold text-blue-300/70 uppercase tracking-wider">Main Menu</p>
                <a href="/admin/dashboard" class="mobile-nav-link group flex items-center gap-2 md:gap-3 px-4 md:px-6 py-2.5 md:py-3 mx-2 rounded-xl text-blue-100 hover:bg-white/10 hover:shadow-lg transition-all duration-300 border-l-4 border-transparent hover:border-purple-400 text-sm md:text-base">
                    <span class="w-8 h-8 md:w-10 md:h-10 rounded-lg bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center shadow-md group-hover:scale-110 transition-transform flex-shrink-0">
                        <i class="fas fa-home text-white text-sm md:text-base"></i>
                    </span>
                    <span class="font-medium">Dashboard</span>
                </a>
                <% if (['Superadmin','Secretary','President'].includes(admin.role)) { %>
                <a href="/admin/membership-applications" class="mobile-nav-link <%= typeof currentPath !== 'undefined' && currentPath.startsWith('/admin/membership-applications') ? 'bg-white/10 shadow-lg border-l-4 border-yellow-400' : 'hover:bg-white/10 hover:shadow-lg border-l-4 border-transparent hover:border-yellow-400' %> group flex items-center gap-2 md:gap-3 px-4 md:px-6 py-2.5 md:py-3 mx-2 rounded-xl text-blue-100 transition-all duration-300 text-sm md:text-base">
                    <span class="w-8 h-8 md:w-10 md:h-10 rounded-lg bg-gradient-to-br from-amber-500 to-orange-500 flex items-center justify-center shadow-md group-hover:scale-110 transition-transform flex-shrink-0">
                        <i class="fas fa-users text-white text-sm md:text-base"></i>
                    </span>
                    <span class="font-medium">Membership Applications</span>
                </a>
                <% } %>
                <a href="/admin/users" class="mobile-nav-link group flex items-center gap-2 md:gap-3 px-4 md:px-6 py-2.5 md:py-3 mx-2 rounded-xl text-blue-100 hover:bg-white/10 hover:shadow-lg transition-all duration-300 border-l-4 border-transparent hover:border-green-400 text-sm md:text-base">
                    <span class="w-8 h-8 md:w-10 md:h-10 rounded-lg bg-gradient-to-br from-emerald-500 to-teal-500 flex items-center justify-center shadow-md group-hover:scale-110 transition-transform flex-shrink-0">
                        <i class="fas fa-users text-white text-sm md:text-base"></i>
                    </span>
                    <span class="font-medium">User Management</span>
                </a>
                <a href="/admin/reports" class="mobile-nav-link group flex items-center gap-2 md:gap-3 px-4 md:px-6 py-2.5 md:py-3 mx-2 rounded-xl text-blue-100 hover:bg-white/10 hover:shadow-lg transition-all duration-300 border-l-4 border-transparent hover:border-cyan-400 text-sm md:text-base">
                    <span class="w-8 h-8 md:w-10 md:h-10 rounded-lg bg-gradient-to-br from-cyan-500 to-blue-500 flex items-center justify-center shadow-md group-hover:scale-110 transition-transform flex-shrink-0">
                        <i class="fas fa-chart-bar text-white text-sm md:text-base"></i>
                    </span>
                    <span class="font-medium">Reports & Analytics</span>
                </a>
                <a href="/admin/audit" class="mobile-nav-link group flex items-center gap-2 md:gap-3 px-4 md:px-6 py-2.5 md:py-3 mx-2 rounded-xl text-blue-100 hover:bg-white/10 hover:shadow-lg transition-all duration-300 border-l-4 border-transparent hover:border-pink-400 text-sm md:text-base">
                    <span class="w-8 h-8 md:w-10 md:h-10 rounded-lg bg-gradient-to-br from-pink-500 to-rose-500 flex items-center justify-center shadow-md group-hover:scale-110 transition-transform flex-shrink-0">
                        <i class="fas fa-file-contract text-white text-sm md:text-base"></i>
                    </span>
                    <span class="font-medium">Audit Logs</span>
                </a>
                <a href="/admin/media" class="mobile-nav-link group flex items-center gap-2 md:gap-3 px-4 md:px-6 py-2.5 md:py-3 mx-2 rounded-xl text-blue-100 hover:bg-white/10 hover:shadow-lg transition-all duration-300 border-l-4 border-transparent hover:border-violet-400 text-sm md:text-base">
                    <span class="w-8 h-8 md:w-10 md:h-10 rounded-lg bg-gradient-to-br from-violet-500 to-purple-500 flex items-center justify-center shadow-md group-hover:scale-110 transition-transform flex-shrink-0">
                        <i class="fas fa-bullhorn text-white text-sm md:text-base"></i>
