<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analytical Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary-bg: #0F1419;
            --card-bg: #1A1F2E;
            --accent-primary: #6366F1;
            --accent-secondary: #10B981;
            --accent-tertiary: #F59E0B;
            --text-primary: #F3F4F6;
            --text-secondary: #9CA3AF;
            --success: #10B981;
            --warning: #F59E0B;
            --danger: #EF4444;
            --border-color: #374151;
        }

        /* Light Theme */
        body.light-theme {
            --primary-bg: #FFFFFF;
            --card-bg: #F9FAFB;
            --accent-primary: #2563EB;
            --accent-secondary: #059669;
            --accent-tertiary: #D97706;
            --text-primary: #111827;
            --text-secondary: #6B7280;
            --border-color: #E5E7EB;
        }

        body {
            background-color: var(--primary-bg);
            color: var(--text-primary);
            font-family: 'Inter', 'Roboto', 'Segoe UI', sans-serif;
            min-height: 100vh;
            transition: background-color 0.3s ease, color 0.3s ease;
            padding: 24px;
        }

        .dashboard-container {
            max-width: 1600px;
            margin: 0 auto;
        }

        /* Header */
        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
            flex-wrap: wrap;
            gap: 16px;
        }

        .header-content h1 {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 8px;
            color: var(--text-primary);
        }

        .header-content p {
            color: var(--text-secondary);
            font-size: 14px;
        }

        .header-controls {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .date-range-selector {
            padding: 8px 16px;
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            color: var(--text-primary);
            font-size: 14px;
            cursor: pointer;
            transition: border-color 0.2s;
        }

        .date-range-selector:hover {
            border-color: var(--accent-primary);
        }

        .theme-toggle {
            padding: 8px 16px;
            background-color: var(--accent-primary);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: background-color 0.2s;
        }

        .theme-toggle:hover {
            opacity: 0.9;
        }

        .export-btn {
            padding: 10px 20px;
            background-color: var(--accent-secondary);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: background-color 0.2s;
        }

        .export-btn:hover {
            background-color: #059669;
        }

        /* KPI Cards */
        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 32px;
        }

        .kpi-card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 24px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            transition: all 0.2s ease;
            border-left: 4px solid var(--accent-primary);
        }

        .kpi-card:hover {
            box-shadow: 0 8px 12px rgba(0, 0, 0, 0.15);
            transform: translateY(-2px);
        }

        .kpi-card.secondary {
            border-left-color: var(--accent-secondary);
        }

        .kpi-card.tertiary {
            border-left-color: var(--accent-tertiary);
        }

        .kpi-card.danger {
            border-left-color: var(--danger);
        }

        .kpi-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 16px;
        }

        .kpi-label {
            color: var(--text-secondary);
            font-size: 14px;
            font-weight: 500;
        }

        .kpi-icon {
            font-size: 28px;
            opacity: 0.7;
        }

        .kpi-value {
            font-size: 36px;
            font-weight: 700;
            margin-bottom: 12px;
            color: var(--text-primary);
        }

        .kpi-variance {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            font-weight: 500;
        }

        .kpi-variance.positive {
            color: var(--success);
        }

        .kpi-variance.negative {
            color: var(--danger);
        }

        .kpi-variance.neutral {
            color: var(--text-secondary);
        }

        .variance-arrow {
            font-size: 16px;
        }

        /* Charts Section */
        .charts-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(480px, 1fr));
            gap: 24px;
            margin-bottom: 32px;
        }

        .chart-card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 24px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .chart-card h3 {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 20px;
            color: var(--text-primary);
        }

        .chart-container {
            position: relative;
            height: 300px;
            margin-bottom: 12px;
        }

        /* Insight Box */
        .insight-box {
            background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
            padding: 16px;
            border-radius: 8px;
            color: white;
            font-size: 13px;
            margin-top: 12px;
        }

        /* Full Width Chart */
        .full-width-chart {
            grid-column: 1 / -1;
        }

        /* Data Table */
        .table-card {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 24px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            margin-bottom: 32px;
        }

        .table-card h3 {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 20px;
            color: var(--text-primary);
        }

        .table-controls {
            display: flex;
            gap: 12px;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }

        .search-input {
            flex: 1;
            min-width: 200px;
            padding: 10px 14px;
            background-color: var(--primary-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            color: var(--text-primary);
            font-size: 14px;
        }

        .search-input::placeholder {
            color: var(--text-secondary);
        }

        .search-input:focus {
            outline: none;
            border-color: var(--accent-primary);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

        .data-table th {
            background-color: var(--primary-bg);
            padding: 12px 16px;
            text-align: left;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-secondary);
            border-bottom: 1px solid var(--border-color);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .data-table td {
            padding: 12px 16px;
            border-bottom: 1px solid var(--border-color);
            font-size: 14px;
        }

        .data-table tr:hover {
            background-color: var(--primary-bg);
        }

        .status-badge {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            text-transform: capitalize;
        }

        .status-badge.active {
            background-color: rgba(16, 185, 129, 0.2);
            color: var(--success);
        }

        .status-badge.pending {
            background-color: rgba(245, 158, 11, 0.2);
            color: var(--warning);
        }

        .status-badge.inactive {
            background-color: rgba(239, 68, 68, 0.2);
            color: var(--danger);
        }

        /* Footer */
        .dashboard-footer {
            padding-top: 24px;
            border-top: 1px solid var(--border-color);
            color: var(--text-secondary);
            font-size: 13px;
            text-align: center;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .dashboard-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .charts-grid {
                grid-template-columns: 1fr;
            }

            .kpi-grid {
                grid-template-columns: 1fr;
            }

            .data-table {
                font-size: 12px;
            }

            .data-table th,
            .data-table td {
                padding: 8px 12px;
            }

            body {
                padding: 16px;
            }
        }

        /* Animations */
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .kpi-card {
            animation: fadeIn 0.5s ease-out forwards;
        }

        .chart-card {
            animation: fadeIn 0.5s ease-out forwards;
        }

        /* Chart.js Custom Colors */
        .chart-canvas {
            color: var(--text-primary);
        }
    </style>
</head>
<body class="light-theme">
    <div class="dashboard-container">
        <!-- Header -->
        <div class="dashboard-header">
            <div class="header-content">
                <h1>📊 Analytical Dashboard</h1>
                <p>Real-time insights & member analytics</p>
            </div>
            <div class="header-controls">
                <select class="date-range-selector" id="dateRangeSelect">
                    <option value="7">Last 7 Days</option>
                    <option value="30" selected>Last 30 Days</option>
                    <option value="90">Last 90 Days</option>
                    <option value="365">Last Year</option>
                </select>
                <button class="theme-toggle" onclick="toggleTheme()">🌙 Dark</button>
                <button class="export-btn" onclick="exportReport()">⬇️ Export Report</button>
            </div>
        </div>

        <!-- KPI Cards -->
        <div class="kpi-grid">
            <div class="kpi-card">
                <div class="kpi-header">
                    <div>
                        <div class="kpi-label">Total Members</div>
                    </div>
                    <div class="kpi-icon">👥</div>
                </div>
                <div class="kpi-value" id="totalMembers">0</div>
                <div class="kpi-variance positive">
                    <span class="variance-arrow">↑</span>
                    <span id="membersVariance">12% from last period</span>
                </div>
            </div>

            <div class="kpi-card secondary">
                <div class="kpi-header">
                    <div>
                        <div class="kpi-label">Pending Applications</div>
                    </div>
                    <div class="kpi-icon">⏳</div>
                </div>
                <div class="kpi-value" id="pendingApps">0</div>
                <div class="kpi-variance neutral">
                    <span class="variance-arrow">→</span>
                    <span>Awaiting review</span>
                </div>
            </div>

            <div class="kpi-card secondary">
                <div class="kpi-header">
                    <div>
                        <div class="kpi-label">Approved Users</div>
                    </div>
                    <div class="kpi-icon">✅</div>
                </div>
                <div class="kpi-value" id="approvedUsers">0</div>
                <div class="kpi-variance positive">
                    <span class="variance-arrow">↑</span>
                    <span>8% this month</span>
                </div>
            </div>

            <div class="kpi-card tertiary">
                <div class="kpi-header">
                    <div>
                        <div class="kpi-label">Active Today</div>
                    </div>
                    <div class="kpi-icon">🔥</div>
                </div>
                <div class="kpi-value" id="activeToday">0</div>
                <div class="kpi-variance positive">
                    <span class="variance-arrow">↑</span>
                    <span id="activeVariance">15% increase</span>
                </div>
            </div>
        </div>

        <!-- Charts -->
        <div class="charts-grid">
            <!-- Members by Division -->
            <div class="chart-card">
                <h3>📍 Members by Division</h3>
                <div class="chart-container">
                    <canvas id="divisionChart"></canvas>
                </div>
                <div class="insight-box">
                    📈 Highest membership concentration in North Division
                </div>
            </div>

            <!-- Gender Distribution -->
            <div class="chart-card">
                <h3>👤 Gender Distribution</h3>
                <div class="chart-container">
                    <canvas id="genderChart"></canvas>
                </div>
                <div class="insight-box">
                    ⚖️ Well-balanced participation across genders
                </div>
            </div>

            <!-- Member Growth Trend -->
            <div class="chart-card full-width-chart">
                <h3>📈 Member Growth Over Time</h3>
                <div class="chart-container" style="height: 320px;">
                    <canvas id="growthChart"></canvas>
                </div>
                <div class="insight-box">
                    🎯 Consistent growth trend with +18% YoY improvement
                </div>
            </div>

            <!-- Members by State (Top 10) -->
            <div class="chart-card full-width-chart">
                <h3>🏆 Top 10 States by Membership</h3>
                <div class="chart-container" style="height: 320px;">
                    <canvas id="stateChart"></canvas>
                </div>
                <div class="insight-box">
                    ⭐ Delhi and Bihar leading with 28% and 24% of total members
                </div>
            </div>
        </div>

        <!-- Real-time User Details Table -->
        <div class="table-card">
            <h3>👥 Recent Members</h3>
            <div class="table-controls">
                <input 
                    type="text" 
                    class="search-input" 
                    id="tableSearch" 
                    placeholder="Search by name, email, or location..."
                    onkeyup="filterTable()"
                >
            </div>
            <div style="overflow-x: auto;">
                <table class="data-table" id="membersTable">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>State</th>
                            <th>Status</th>
                            <th>Joined</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                        <!-- Populated by JavaScript -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Footer -->
        <div class="dashboard-footer">
            <p>🔄 Last updated: <span id="lastUpdate">Just now</span> | Data refreshes every 5 minutes</p>
        </div>
    </div>

    <script>
        // Theme Toggle
        function toggleTheme() {
            document.body.classList.toggle('light-theme');
            localStorage.setItem('theme', document.body.classList.contains('light-theme') ? 'light' : 'dark');
        }

        // Load saved theme
        if (localStorage.getItem('theme') === 'dark') {
            document.body.classList.remove('light-theme');
        }

        // Chart instances
        let charts = {
            division: null,
            gender: null,
            growth: null,
            state: null
        };

        // Fetch analytics data
        async function loadDashboard() {
            try {
                const response = await fetch('/admin/api/analytics');
                const data = await response.json();

                // Update KPIs
                document.getElementById('totalMembers').textContent = data.stats.totalMembers.toLocaleString();
                document.getElementById('pendingApps').textContent = data.stats.pendingApplications;
                document.getElementById('approvedUsers').textContent = data.stats.approvedUsers;
                document.getElementById('activeToday').textContent = data.stats.activeToday;

                // Update timestamp
                document.getElementById('lastUpdate').textContent = new Date().toLocaleTimeString();

                // Initialize charts
                initDivisionChart(data.divisions);
                initGenderChart(data.genders);
                initGrowthChart(data.growth);
                initStateChart(data.topStates);

                // Populate table
                populateTable(data.recentMembers);
            } catch (error) {
                console.error('Error loading dashboard:', error);
            }
        }

        // Division Chart (Bar)
        function initDivisionChart(data) {
            const ctx = document.getElementById('divisionChart').getContext('2d');
            
            if (charts.division) charts.division.destroy();
            
            charts.division = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: data.labels,
                    datasets: [{
                        label: 'Members',
                        data: data.values,
                        backgroundColor: [
                            '#6366F1',
                            '#10B981',
                            '#F59E0B',
                            '#EF4444',
                            '#06B6D4'
                        ],
                        borderRadius: 8,
                        borderSkipped: false,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: 'rgba(255,255,255,0.05)'
                            },
                            ticks: {
                                color: '#9CA3AF'
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            },
                            ticks: {
                                color: '#9CA3AF'
                            }
                        }
                    }
                }
            });
        }

        // Gender Chart (Doughnut)
        function initGenderChart(data) {
            const ctx = document.getElementById('genderChart').getContext('2d');
            
            if (charts.gender) charts.gender.destroy();
            
            charts.gender = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: data.labels,
                    datasets: [{
                        data: data.values,
                        backgroundColor: [
                            '#6366F1',
                            '#EC4899',
                            '#F59E0B'
                        ],
                        borderColor: '#1A1F2E',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                color: '#F3F4F6',
                                padding: 15,
                                font: {
                                    size: 13
                                }
                            }
                        }
                    }
                }
            });
        }

        // Growth Chart (Line)
        function initGrowthChart(data) {
            const ctx = document.getElementById('growthChart').getContext('2d');
            
            if (charts.growth) charts.growth.destroy();
            
            charts.growth = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: data.labels,
                    datasets: [{
                        label: 'Members',
                        data: data.values,
                        borderColor: '#6366F1',
                        backgroundColor: 'rgba(99, 102, 241, 0.1)',
                        borderWidth: 3,
                        fill: true,
                        tension: 0.4,
                        pointBackgroundColor: '#6366F1',
                        pointBorderColor: '#1A1F2E',
                        pointBorderWidth: 2,
                        pointRadius: 5,
                        pointHoverRadius: 7
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: 'rgba(255,255,255,0.05)'
                            },
                            ticks: {
                                color: '#9CA3AF'
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            },
                            ticks: {
                                color: '#9CA3AF'
                            }
                        }
                    }
                }
            });
        }

        // State Chart (Horizontal Bar)
        function initStateChart(data) {
            const ctx = document.getElementById('stateChart').getContext('2d');
            
            if (charts.state) charts.state.destroy();
            
            charts.state = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: data.labels,
                    datasets: [{
                        label: 'Members',
                        data: data.values,
                        backgroundColor: [
                            '#6366F1',
                            '#10B981',
                            '#F59E0B',
                            '#06B6D4',
                            '#EC4899',
                            '#8B5CF6',
                            '#F97316',
                            '#14B8A6',
                            '#6366F1',
                            '#10B981'
                        ],
                        borderRadius: 8,
                        borderSkipped: false,
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        x: {
                            beginAtZero: true,
                            grid: {
                                color: 'rgba(255,255,255,0.05)'
                            },
                            ticks: {
                                color: '#9CA3AF'
                            }
                        },
                        y: {
                            grid: {
                                display: false
                            },
                            ticks: {
                                color: '#9CA3AF'
                            }
                        }
                    }
                }
            });
        }

        // Populate Table
        function populateTable(members) {
            const tbody = document.getElementById('tableBody');
            tbody.innerHTML = '';

            members.forEach(member => {
                // Determine status based on last update
                const lastUpdate = new Date(member.updatedAt);
                const daysSinceUpdate = Math.floor((new Date() - lastUpdate) / (1000 * 60 * 60 * 24));
                const status = daysSinceUpdate < 30 ? 'active' : 'inactive';
                
                const joinedDate = new Date(member.createdAt).toLocaleDateString();

                const row = document.createElement('tr');
                row.innerHTML = `
                    <td><strong>${member.fullName}</strong></td>
                    <td>${member.email}</td>
                    <td>${member.state}</td>
                    <td>
                        <span class="status-badge ${status}">
                            ${status === 'active' ? 'Active' : 'Inactive'}
                        </span>
                    </td>
                    <td>${joinedDate}</td>
                    <td>
                        <a href="/admin/members/${member._id}" style="color: #6366F1; text-decoration: none; font-weight: 600;">
                            View →
                        </a>
                    </td>
                `;
                tbody.appendChild(row);
            });
        }

        // Filter Table
        function filterTable() {
            const input = document.getElementById('tableSearch');
            const filter = input.value.toLowerCase();
            const table = document.getElementById('membersTable');
            const rows = table.getElementsByTagName('tr');

            for (let i = 1; i < rows.length; i++) {
                const row = rows[i];
                const text = row.textContent || row.innerText;
                row.style.display = text.toLowerCase().includes(filter) ? '' : 'none';
            }
        }

        // Export Report
        function exportReport() {
            const table = document.getElementById('membersTable');
            let csv = 'Name,Email,State,Status,Joined\n';
            const rows = table.querySelectorAll('tbody tr');

            rows.forEach(row => {
                const cells = row.querySelectorAll('td');
                const rowData = Array.from(cells).slice(0, 5).map(cell => '"' + cell.textContent + '"').join(',');
                csv += rowData + '\n';
            });

            const blob = new Blob([csv], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `members-report-${new Date().toISOString().split('T')[0]}.csv`;
            a.click();
        }

        // Load dashboard on page load
        document.addEventListener('DOMContentLoaded', loadDashboard);

        // Refresh data every 5 minutes
        setInterval(loadDashboard, 5 * 60 * 1000);
    </script>
</body>
</html>
