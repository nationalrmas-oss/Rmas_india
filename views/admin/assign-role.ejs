<div class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100 p-6">
    <div class="max-w-2xl mx-auto">
        <!-- Header -->
        <div class="bg-white rounded-xl shadow-lg p-6 mb-6 border border-blue-100">
            <div class="flex items-center gap-4 mb-4">
                <div class="w-16 h-16 rounded-full bg-gradient-to-br from-blue-400 to-indigo-500 flex items-center justify-center text-white text-2xl font-bold">
                    <% if (member.photo) { %>
                        <img src="/uploads/<%= member.photo %>" alt="photo" class="w-full h-full rounded-full object-cover" onerror="this.style.display='none'">
                    <% } else { %>
                        <%= member.fullName.charAt(0).toUpperCase() %>
                    <% } %>
                </div>
                <div>
                    <h1 class="text-3xl font-bold text-gray-800">📌 Role Assignment</h1>
                    <p class="text-gray-600"><%= member.fullName %></p>
                    <p class="text-sm text-gray-500"><%= member.district %>, <%= member.state %></p>
                </div>
            </div>
        </div>

        <!-- Form Container -->
        <div class="bg-white rounded-xl shadow-lg p-8 border border-blue-100">
            <form id="roleAssignForm" onsubmit="handleSubmit(event)">
                <!-- Position Selection -->
                <div class="mb-6">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">📋 Select Position *</label>
                    <select name="position" id="position" required class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none transition-colors text-gray-800">
                        <option value="">-- Choose a Position --</option>
                        <% positions.forEach(pos => { %>
                            <% const limit = roleLimits[pos]; %>
                            <option value="<%= pos %>"><%= pos %><% if (limit) { %> (max <%= limit %>)<% } %></option>
                        <% }); %>
                    </select>
                    <span class="text-red-500 text-sm hidden" id="positionError"></span>
                </div>

                <!-- Team Selection -->
                <div class="mb-6">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">👥 Select Team *</label>
                    <select name="teamType" id="teamType" required class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none transition-colors text-gray-800">
                        <option value="">-- Choose a Team --</option>
                        <option value="Core">Core</option>
                        <option value="Mahila">Mahila</option>
                        <option value="Yuva">Yuva</option>
                        <option value="Alpsankhyak">Alpsankhyak</option>
                        <option value="SC/ST">SC/ST</option>
                    </select>
                    <span class="text-red-500 text-sm hidden" id="teamTypeError"></span>
                </div>

                <!-- Level Selection -->
                <div class="mb-6">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">🏛️ Select Level *</label>
                    <select name="level" id="level" required onchange="updateLocationFields()" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none transition-colors text-gray-800">
                        <option value="">-- Choose a Level --</option>
                        <% if (allowedLevels && allowedLevels.length) { %>
                            <% allowedLevels.forEach(lvl => { %>
                                <option value="<%= lvl %>"><%= lvl %></option>
                            <% }); %>
                        <% } %>
                    </select>
                    <span class="text-red-500 text-sm hidden" id="levelError"></span>
                </div>

                <!-- Location Fields -->
                <div id="locationFields" class="space-y-4">
                    <!-- State -->
                    <div id="stateField" class="hidden">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">📍 State *</label>
                        <select name="state" id="state" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none transition-colors text-gray-800">
                            <option value="">-- Select State --</option>
                            <% if (adminLocation && adminLocation.state && admin.level !== 'National' && admin.role !== 'Superadmin') { %>
                                <option value="<%= adminLocation.state %>" selected><%= adminLocation.state %></option>
                                <script>document.addEventListener('DOMContentLoaded',()=>{document.getElementById('state').disabled=true;document.getElementById('state').dispatchEvent(new Event('change'));});</script>
                            <% } else { %>
                                <option value="Bihar">Bihar</option>
                                <option value="Delhi">Delhi</option>
                                <option value="Jharkhand">Jharkhand</option>
                                <option value="Madhya Pradesh">Madhya Pradesh</option>
                                <option value="Uttar Pradesh">Uttar Pradesh</option>
                                <option value="West Bengal">West Bengal</option>
                            <% } %>
                        </select>
                    </div>

                    <!-- Division -->
                    <div id="divisionField" class="hidden">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">🏛️ Division *</label>
                        <select name="division" id="division" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none transition-colors text-gray-800">
                            <option value="">-- Select Division --</option>
                        </select>
                    </div>

                    <!-- District -->
                    <div id="districtField" class="hidden">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">📍 District *</label>
                        <select name="district" id="district" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none transition-colors text-gray-800">
                            <option value="">-- Select District --</option>
                        </select>
                    </div>

                    <!-- Block -->
                    <div id="blockField" class="hidden">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">🏘️ Block *</label>
                        <select name="block" id="block" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none transition-colors text-gray-800">
                            <option value="">-- Select Block --</option>
                        </select>
                    </div>

                    <!-- Panchayat -->
                    <div id="panchayatField" class="hidden">
                        <label class="block text-sm font-semibold text-gray-700 mb-2">🏘️ Panchayat *</label>
                        <input type="text" name="panchayat" id="panchayat" placeholder="Enter Panchayat name" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:outline-none transition-colors text-gray-800">
                    </div>
                </div>

                <!-- Buttons -->
                <div class="flex gap-4 mt-8">
                    <button type="submit" class="flex-1 px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors shadow-md">
                        ✅ Assign Position
                    </button>
                    <a href="/admin/membership-applications/<%= member._id %>" class="flex-1 px-6 py-3 bg-gray-500 hover:bg-gray-600 text-white font-semibold rounded-lg transition-colors shadow-md text-center">
                        ❌ Cancel
                    </a>
                </div>
            </form>
        </div>

        <!-- Info Box -->
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-6 mt-6">
            <h3 class="font-semibold text-blue-900 mb-2">📌 Information</h3>
            <ul class="text-sm text-blue-800 space-y-1">
                <li>✓ Position will be assigned to team members</li>
                <li>✓ Member profile will be updated automatically</li>
                <li>✓ Hierarchy permissions will be enforced</li>
            </ul>
        </div>
    </div>
</div>

<script>
// expose server data to script
const adminLocation = <%- JSON.stringify(adminLocation || {}) %>;
const admin = <%- JSON.stringify(admin || {}) %>;
const roleLimits = <%- JSON.stringify(roleLimits || {}) %>;

// Cached location data
let locationCache = {};

function getFileNameForState(state) {
    const mapping = {
        'Bihar': 'bihar',
        'Delhi': 'delhi',
        'Jharkhand': 'jharkhand',
        'Madhya Pradesh': 'madhya_pradesh',
        'Uttar Pradesh': 'uttar_pradesh',
        'West Bengal': 'west_bengal'
    };
    return mapping[state] || state.toLowerCase();
}

async function fetchLocationData(state) {
    if (locationCache[state]) {
        return locationCache[state];
    }
    try {
        const filename = getFileNameForState(state);
        const response = await fetch(`/locations/${filename}.json`);
        if (response.ok) {
            const data = await response.json();
            locationCache[state] = data;
            return data;
        }
    } catch (error) {
        console.error('Error fetching location data:', error);
    }
    return null;
}

async function updateLocationFields() {
    const level = document.getElementById('level').value;
    
    console.log('🔄 Level changed to:', level);
    
    // Save admin location values before clearing
    const savedState = document.getElementById('state').value;
    const savedDivision = document.getElementById('division').value;
    const savedDistrict = document.getElementById('district').value;
    const savedBlock = document.getElementById('block').value;
    
    // Reset all fields - COMPLETELY
    document.getElementById('stateField').classList.add('hidden');
    document.getElementById('divisionField').classList.add('hidden');
    document.getElementById('districtField').classList.add('hidden');
    document.getElementById('blockField').classList.add('hidden');
    document.getElementById('panchayatField').classList.add('hidden');
    
    // Remove required attribute from all
    document.getElementById('state').required = false;
    document.getElementById('division').required = false;
    document.getElementById('district').required = false;
    document.getElementById('block').required = false;
    document.getElementById('panchayat').required = false;

    // Clear only non-admin-restricted values
    if (!document.getElementById('state').disabled) document.getElementById('state').value = '';
    if (!document.getElementById('division').disabled) document.getElementById('division').value = '';
    if (!document.getElementById('district').disabled) document.getElementById('district').value = '';
    if (!document.getElementById('block').disabled) document.getElementById('block').value = '';
    document.getElementById('panchayat').value = '';

    // Show fields based on selected level
    switch(level) {
        case 'National':
            console.log('✅ National - No location fields needed');
            break;
        case 'State':
            console.log('✅ State - Showing State field only');
            document.getElementById('stateField').classList.remove('hidden');
            document.getElementById('state').required = true;
            break;
        case 'Division':
            console.log('✅ Division - Showing State + Division');
            document.getElementById('stateField').classList.remove('hidden');
            document.getElementById('divisionField').classList.remove('hidden');
            document.getElementById('state').required = true;
            document.getElementById('division').required = true;
            break;
        case 'District':
            console.log('✅ District - Showing State + Division + District ONLY');
            document.getElementById('stateField').classList.remove('hidden');
            document.getElementById('divisionField').classList.remove('hidden');
            document.getElementById('districtField').classList.remove('hidden');
            document.getElementById('state').required = true;
            document.getElementById('division').required = true;
            document.getElementById('district').required = true;
            // ensure division change handler runs even if control is disabled
            const divEl = document.getElementById('division');
            const wasDisabled = divEl.disabled;
            if (divEl.value) {
                divEl.disabled = false;
                divEl.dispatchEvent(new Event('change'));
                divEl.disabled = wasDisabled;
            }
            break;
        case 'Block':
            console.log('✅ Block - Showing State + Division + District + Block');
            document.getElementById('stateField').classList.remove('hidden');
            document.getElementById('divisionField').classList.remove('hidden');
            document.getElementById('districtField').classList.remove('hidden');
            document.getElementById('blockField').classList.remove('hidden');
            document.getElementById('state').required = true;
            document.getElementById('division').required = true;
            document.getElementById('district').required = true;
            document.getElementById('block').required = true;
            // restore district value and trigger change to load blocks
            if (savedDistrict) {
                document.getElementById('district').value = savedDistrict;
                document.getElementById('district').dispatchEvent(new Event('change'));
            }
            break;
        case 'Panchayat':
            console.log('✅ Panchayat - Showing All fields');
            document.getElementById('stateField').classList.remove('hidden');
            document.getElementById('divisionField').classList.remove('hidden');
            document.getElementById('districtField').classList.remove('hidden');
            document.getElementById('blockField').classList.remove('hidden');
            document.getElementById('panchayatField').classList.remove('hidden');
            document.getElementById('state').required = true;
            document.getElementById('division').required = true;
            document.getElementById('district').required = true;
            document.getElementById('block').required = true;
            document.getElementById('panchayat').required = true;
            // restore district value and trigger change to load blocks
            if (savedDistrict) {
                document.getElementById('district').value = savedDistrict;
                document.getElementById('district').dispatchEvent(new Event('change'));
            }
            break;
    }
}

// State change handler
document.getElementById('state').addEventListener('change', async function() {
    const state = this.value;
    const divisionSelect = document.getElementById('division');
    divisionSelect.innerHTML = '<option value="">-- Loading --</option>';

    if (!state) {
        divisionSelect.innerHTML = '<option value="">-- Select Division --</option>';
        document.getElementById('districtField').classList.add('hidden');
        document.getElementById('blockField').classList.add('hidden');
        return;
    }

    const data = await fetchLocationData(state);
    divisionSelect.innerHTML = '<option value="">-- Select Division --</option>';
    
    if (data && data.divisions) {
        Object.keys(data.divisions).forEach(division => {
            // if admin has a specific division restriction, skip others
            if (adminLocation && adminLocation.division && admin.level !== 'National' && admin.role !== 'Superadmin') {
                if (division !== adminLocation.division) return;
            }
            divisionSelect.innerHTML += `<option value="${division}">${division}</option>`;
        });
    }

    // if admin is restricted to a division, preselect and disable
    if (adminLocation && adminLocation.division && admin.level !== 'National' && admin.role !== 'Superadmin') {
        divisionSelect.value = adminLocation.division;
        divisionSelect.disabled = true;
        divisionSelect.dispatchEvent(new Event('change'));
    }

    // only reveal district choices for levels that need them
    const currLevel = document.getElementById('level').value;
    if (currLevel === 'District' || currLevel === 'Block' || currLevel === 'Panchayat') {
        document.getElementById('districtField').classList.remove('hidden');
    } else {
        document.getElementById('districtField').classList.add('hidden');
    }
});

// Division change handler
document.getElementById('division').addEventListener('change', async function() {
    const state = document.getElementById('state').value;
    const division = this.value;
    console.log('🔁 division changed->', division, 'state->', state);
    const districtSelect = document.getElementById('district');
    
    if (!state || !division) {
        districtSelect.innerHTML = '<option value="">-- Select District --</option>';
        return;
    }

    const data = await fetchLocationData(state);
    districtSelect.innerHTML = '<option value="">-- Select District --</option>';
    
    if (data && data.divisions && data.divisions[division] && data.divisions[division].districts) {
        Object.keys(data.divisions[division].districts).forEach(district => {
            // restrict to admin's district if set and not national
            if (adminLocation && adminLocation.district && admin.level !== 'National' && admin.role !== 'Superadmin') {
                if (district !== adminLocation.district) return;
            }
            districtSelect.innerHTML += `<option value="${district}">${district}</option>`;
        });
    }

    // if admin has a district restriction, preselect and disable
    if (adminLocation && adminLocation.district && admin.level !== 'National' && admin.role !== 'Superadmin') {
        districtSelect.value = adminLocation.district;
        districtSelect.disabled = true;
        districtSelect.dispatchEvent(new Event('change')); // trigger change to possibly load blocks / hide
    }

    // only show blocks if assigning at Block/Panchayat level
    const currentLevel = document.getElementById('level').value;
    if (currentLevel === 'Block' || currentLevel === 'Panchayat') {
        document.getElementById('blockField').classList.remove('hidden');
    } else {
        document.getElementById('blockField').classList.add('hidden');
    }
});

// District change handler
document.getElementById('district').addEventListener('change', async function() {
    const state = document.getElementById('state').value;
    const division = document.getElementById('division').value;
    const district = this.value;
    const blockSelect = document.getElementById('block');
    
    if (!state || !division || !district) {
        blockSelect.innerHTML = '<option value="">-- Select Block --</option>';
        return;
    }

    const data = await fetchLocationData(state);
    blockSelect.innerHTML = '<option value="">-- Select Block --</option>';
    
    if (data && data.divisions && data.divisions[division] && data.divisions[division].districts && data.divisions[division].districts[district]) {
        const blocks = data.divisions[division].districts[district];
        if (Array.isArray(blocks)) {
            blocks.forEach(block => {
                // restrict to admin's block if set and not national
                if (adminLocation && adminLocation.block && admin.level !== 'National' && admin.role !== 'Superadmin') {
                    if (block !== adminLocation.block) return;
                }
                blockSelect.innerHTML += `<option value="${block}">${block}</option>`;
            });
        }
    }

    // if admin has a block restriction, preselect and disable
    if (adminLocation && adminLocation.block && admin.level !== 'National' && admin.role !== 'Superadmin') {
        blockSelect.value = adminLocation.block;
        blockSelect.disabled = true;
    }
});

// initialization helper - prefill fields from admin's own location
function initAdminLocation() {
    if (!adminLocation) return;
    if (adminLocation.state) {
        document.getElementById('state').value = adminLocation.state;
        document.getElementById('state').dispatchEvent(new Event('change'));
    }
    if (adminLocation.division) {
        document.getElementById('division').value = adminLocation.division;
        document.getElementById('division').dispatchEvent(new Event('change'));
    }
    if (adminLocation.district) {
        document.getElementById('district').value = adminLocation.district;
        document.getElementById('district').dispatchEvent(new Event('change'));
    }
    if (adminLocation.block) {
        document.getElementById('block').value = adminLocation.block;
    }
}

document.addEventListener('DOMContentLoaded', () => {
    initAdminLocation();
});

// form submission handler
async function handleSubmit(event) {
    event.preventDefault();
    const position = document.getElementById('position').value;
    const teamType = document.getElementById('teamType').value;
    const level = document.getElementById('level').value;
    const state = document.getElementById('state').value;
    const division = document.getElementById('division').value;
    const district = document.getElementById('district').value;
    const block = document.getElementById('block').value;
    const panchayat = document.getElementById('panchayat').value;

    // Validation
    if (!position) {
        alert('❌ Please select a position');
        return;
    }
    if (!teamType) {
        alert('❌ Please select a team');
        return;
    }
    if (!level) {
        alert('❌ Please select a level');
        return;
    }

    const data = { position, teamType, level, state: state || '', division: division || '', district: district || '', block: block || '', panchayat: panchayat || '' };

    try {
        const response = await fetch('', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        let result;
        try {
            result = await response.json();
        } catch (jsonErr) {
            // Not JSON, show clear alert
            const text = await response.text();
            alert('❌ Server error: Response was not JSON.\n' + text.slice(0, 300));
            return;
        }
        if (result.success) {
            alert('✅ Position assigned successfully!');
            window.location.href = '/admin/membership-applications/<%= member._id %>?success=role_assigned';
        } else {
            let msg = result.message || result.error || 'Unknown error';
            if (result.reason && msg.indexOf('Limit') === -1) msg += '\nReason: ' + result.reason;
            if (msg.toLowerCase().includes('limit')) msg = '❌ Limit Reached: ' + msg;
            if (result.details) msg += '\nDetails: ' + result.details;
            alert(msg);
        }
    } catch (error) {
        console.error('Error:', error);
        alert('❌ Error assigning position');
    }
}

// attach submit listener
document.getElementById('roleAssignForm').addEventListener('submit', handleSubmit);

</script>
