                        <%= (admin.fullName || 'A').charAt(0).toUpperCase() %>
                    </div>
                </div>
                <h3 class="text-center font-bold text-lg text-white"><%= admin.fullName %></h3>
                <p class="text-center text-sm text-blue-300 bg-blue-800/30 py-1 px-3 rounded-full mt-2 inline-block"><%= admin.role %></p>
            </div>

            <!-- Scrollable Sidebar Content -->
