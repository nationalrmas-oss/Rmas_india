                <a href="/admin/dashboard" class="group flex items-center gap-3 px-6 py-3 mx-2 rounded-xl text-blue-100 hover:bg-white/10 hover:shadow-lg transition-all duration-300 border-l-4 border-transparent hover:border-purple-400">
                    <span class="w-10 h-10 rounded-lg bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center shadow-md group-hover:scale-110 transition-transform">
                        <i class="fas fa-home text-white"></i>
                    </span>
                    <span class="font-medium">Dashboard</span>
                </a>

                <a href="/admin/membership-applications" class="<%= typeof currentPath !== 'undefined' && currentPath.startsWith('/admin/membership-applications') ? 'bg-white/10 shadow-lg border-l-4 border-yellow-400' : 'hover:bg-white/10 hover:shadow-lg border-l-4 border-transparent hover:border-yellow-400' %> group flex items-center gap-3 px-6 py-3 mx-2 rounded-xl text-blue-100 transition-all duration-300">
                    <span class="w-10 h-10 rounded-lg bg-gradient-to-br from-amber-500 to-orange-500 flex items-center justify-center shadow-md group-hover:scale-110 transition-transform">
                        <i class="fas fa-users text-white"></i>
                    </span>
                    <span class="font-medium">Membership Applications</span>
                </a>

